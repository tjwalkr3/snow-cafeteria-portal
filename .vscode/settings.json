{
  "[csharp]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 4
  },
  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true
  },
  "files.associations": {
    "*.yml": "yaml",
    "*.yaml": "yaml"
  },
  "python.defaultInterpreterPath": "${workspaceFolder}/ReceiptPrinter/.venv/bin/python",
  "files.exclude": {
    "ReceiptPrinter/.venv": true
  },
  "cSpell.words": [
    "rendermode"
  ]
}
