@page "/"
@rendermode InteractiveServer
@using System.Text.Json
@using System.Text.Json.Nodes
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Select Payment Method</PageTitle>

<div class="container py-4 px-1">
    <div class="text-center mb-5">
        <h1 class="payment-title mb-2 fs-2 fw-bold">Choose Payment Method</h1>
        <p class="payment-subtitle fs-6 mb-0">Select how you'd like to pay for your order</p>
    </div>

    @if (!AnyLocationsOpen)
    {
        <div class="alert alert-warning text-center mb-4" role="alert">
            <i class="bi bi-clock me-2"></i>
            <strong>No locations are currently open.</strong> Payment methods are unavailable until a location opens.
        </div>
    }

    <div class="row row-cols-1 row-cols-md-2 g-4 justify-content-center">
        <div class="col">
            @if (HasSwipes && AnyLocationsOpen)
            {
                <button class="card-link text-decoration-none d-block w-100 p-0 border-0 bg-transparent"
                        @onclick="() => HandlePaymentSelected(false)">
                    <div class="card h-100 selection-card position-relative @(CurrentIsCardOrder.HasValue && !CurrentIsCardOrder.Value ? "card-selected" : "")">
                        @if (CurrentIsCardOrder.HasValue && !CurrentIsCardOrder.Value)
                        {
                            <span class="card-selected-badge">Selected</span>
                        }
                        <div class="card-body text-center p-4">
                            <div class="mb-4">
                                <div class="icon-circle">
                                    <i class="bi bi-credit-card-2-front fs-2"></i>
                                </div>
                            </div>
                            <h3 class="card-title payment-card-title mb-3 fs-4 fw-bold">Meal Plan Swipe</h3>
                            <p class="payment-card-description mb-0 fs-6">Use your student ID card</p>
                        </div>
                    </div>
                </button>
            }
            else
            {
                <div class="card h-100 selection-card disabled-card" @onclick="@(!HasSwipes ? ShowNoSwipesAlert : () => Task.CompletedTask)">
                    <div class="card-body text-center p-4">
                        <div class="mb-2">
                            <div class="icon-circle">
                                <i class="bi bi-credit-card-2-front fs-2"></i>
                            </div>
                        </div>
                        <h3 class="card-title payment-card-title fs-4 fw-bold mb-1">Meal Plan Swipe</h3>
                        <p class="payment-card-description mb-0 fs-6">Use your student ID card</p>
                        @if (!HasSwipes)
                        {
                            <p class="mt-1 mb-0 fs-6 text-danger"><strong>No swipes available</strong></p>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="col">
            @if (AnyLocationsOpen)
            {
                <button class="card-link text-decoration-none d-block w-100 p-0 border-0 bg-transparent"
                        @onclick="() => HandlePaymentSelected(true)">
                    <div class="card h-100 selection-card position-relative @(CurrentIsCardOrder.HasValue && CurrentIsCardOrder.Value ? "card-selected" : "")">
                        @if (CurrentIsCardOrder.HasValue && CurrentIsCardOrder.Value)
                        {
                            <span class="card-selected-badge">Selected</span>
                        }
                        <div class="card-body text-center p-4">
                            <div class="mb-4">
                                <div class="icon-circle">
                                    <i class="bi bi-wallet2 fs-2"></i>
                                </div>
                            </div>
                            <h3 class="card-title payment-card-title mb-3 fs-4 fw-bold">Credit/Debit Card</h3>
                            <p class="payment-card-description mb-0 fs-6">Pay securely with your credit
                                or debit card. We accept all major cards.</p>
                        </div>
                    </div>
                </button>
            }
            else
            {
                <div class="card h-100 selection-card disabled-card">
                    <div class="card-body text-center p-4">
                        <div class="mb-4">
                            <div class="icon-circle">
                                <i class="bi bi-wallet2 fs-2"></i>
                            </div>
                        </div>
                        <h3 class="card-title payment-card-title mb-3 fs-4 fw-bold">Credit/Debit Card</h3>
                        <p class="payment-card-description mb-0 fs-6">Pay securely with your credit
                            or debit card. We accept all major cards.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<ConfirmationModal
    IsVisible="ShowConfirmModal"
    Title="Change Payment Method?"
    Message="Changing your payment method will clear your current cart. Do you want to continue?"
    ConfirmText="Yes, Change Payment"
    OnConfirm="ConfirmPaymentChange"
    OnCancel="CancelPaymentChange" />
