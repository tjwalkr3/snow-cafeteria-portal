@using Cafeteria.Customer.Components.Pages.Stations.Panels.EntreePanel
@using Cafeteria.Shared.DTOs.Menu

<div class="row row-cols-1 row-cols-lg-3 g-3">
    @foreach (var entree in Entrees)
    {
        var cardQty = IsCardOrder ? (CardQuantities?.GetValueOrDefault(entree.Id, 0) ?? 0) : 0;
        var isHighlighted = IsCardOrder ? cardQty > 0 : SelectedEntree?.Id == entree.Id;
        <div class="col">
            <div class="meal-card d-flex flex-column @(isHighlighted ? "selected" : "")"
                 @onclick="() => OnEntreeSelected.InvokeAsync(entree)">
                <div class="flex-grow-1">
                    <h5 class="mb-1 fw-600">@entree.EntreeName</h5>
                    @if (!string.IsNullOrEmpty(entree.EntreeDescription))
                    {
                        <p class="text-muted mb-0" style="font-size: 0.9rem;">@entree.EntreeDescription</p>
                    }
                    @if (!IsCardOrder && SelectedEntree?.Id == entree.Id && SelectedBadges.Any())
                    {
                        <div class="d-flex flex-wrap gap-1 mt-2">
                            @foreach (var badge in SelectedBadges)
                            {
                                <span class="badge rounded-pill bg-light text-dark border" style="font-size: 0.75rem;">@badge</span>
                            }
                        </div>
                    }
                    @if (IsCardOrder && cardQty > 0)
                    {
                        var cardOptions = GetCardEntreeOptions(entree.Id);
                        @if (cardOptions.Any())
                        {
                            <div class="d-flex flex-wrap gap-1 mt-2">
                                @foreach (var badge in cardOptions)
                                {
                                    <span class="badge rounded-pill bg-light text-dark border" style="font-size: 0.75rem;">@badge</span>
                                }
                            </div>
                        }
                    }
                </div>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    @if (IsCardOrder)
                    {
                        <span class="price-badge">$@entree.EntreePrice.ToString("F2")</span>
                    }
                    else
                    {
                        <span></span>
                    }
                    @if (IsCardOrder && cardQty > 0)
                    {
                        <div class="qty-stepper d-inline-flex align-items-center" @onclick:stopPropagation="true">
                            <button type="button" class="qty-btn" @onclick="() => OnCardQtyChanged.InvokeAsync((entree.Id, cardQty - 1))">
                                <i class="bi bi-dash"></i>
                            </button>
                            <span class="qty-value">@cardQty</span>
                            <button type="button" class="qty-btn" @onclick="() => OnCardQtyChanged.InvokeAsync((entree.Id, cardQty + 1))">
                                <i class="bi bi-plus"></i>
                            </button>
                        </div>
                    }
                    else if (!IsCardOrder && IsComplete(entree))
                    {
                        <button type="button" class="select-btn added d-inline-flex align-items-center gap-1"
                                @onclick="() => OnEntreeSelected.InvokeAsync(entree)" @onclick:stopPropagation="true">
                            <i class="bi bi-check-circle-fill"></i> Added
                        </button>
                    }
                    else
                    {
                        <button type="button" class="select-btn d-inline-flex align-items-center gap-1"
                                @onclick="() => OnEntreeSelected.InvokeAsync(entree)" @onclick:stopPropagation="true">
                            <i class="bi bi-plus-circle"></i> Add
                        </button>
                    }
                </div>
            </div>
        </div>
    }
</div>
