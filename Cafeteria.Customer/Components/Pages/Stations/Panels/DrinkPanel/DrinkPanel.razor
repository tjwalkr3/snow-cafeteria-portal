@using Cafeteria.Shared.DTOs.Menu

@if (Drinks.Any())
{
    <div class="row row-cols-1 row-cols-lg-3 g-3">
        @foreach (var drink in Drinks)
        {
            var cardQty = IsCardOrder ? (CardQuantities?.GetValueOrDefault(drink.Id, 0) ?? 0) : 0;
            var isHighlighted = IsCardOrder ? cardQty > 0 : SelectedDrink?.Id == drink.Id;
            <div class="col">
                <div class="meal-card h-100 d-flex flex-column @(isHighlighted ? "selected" : "")" @onclick="() => OnDrinkSelected.InvokeAsync(drink)">
                    <div class="flex-grow-1">
                        <h5 class="mb-1 fw-600">@drink.DrinkName</h5>
                        @if (!string.IsNullOrEmpty(drink.DrinkDescription))
                        {
                            <p class="text-muted mb-0" style="font-size: 0.9rem;">@drink.DrinkDescription</p>
                        }
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        @if (IsCardOrder)
                        {
                            <span class="price-badge">$@drink.DrinkPrice.ToString("F2")</span>
                        }
                        else
                        {
                            <span></span>
                        }
                        @if (IsCardOrder && cardQty > 0)
                        {
                            <div class="qty-stepper d-inline-flex align-items-center" @onclick:stopPropagation="true">
                                <button type="button" class="qty-btn" @onclick="() => OnCardQtyChanged.InvokeAsync((drink.Id, cardQty - 1))">
                                    <i class="bi bi-dash"></i>
                                </button>
                                <span class="qty-value">@cardQty</span>
                                <button type="button" class="qty-btn" @onclick="() => OnCardQtyChanged.InvokeAsync((drink.Id, cardQty + 1))">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </div>
                        }
                        else if (!IsCardOrder && SelectedDrink?.Id == drink.Id && Quantity > 0)
                        {
                            <div class="qty-stepper d-inline-flex align-items-center" @onclick:stopPropagation="true">
                                <button type="button" class="qty-btn" @onclick="() => OnQuantityChanged.InvokeAsync(Quantity - 1)">
                                    <i class="bi bi-dash"></i>
                                </button>
                                <span class="qty-value">@Quantity</span>
                                <button type="button" class="qty-btn" @onclick="() => OnQuantityChanged.InvokeAsync(Quantity + 1)">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </div>
                        }
                        else if (!IsCardOrder && SelectedDrink?.Id == drink.Id)
                        {
                            <button type="button" class="select-btn added d-inline-flex align-items-center gap-1"
                                    @onclick="() => OnDrinkSelected.InvokeAsync(drink)" @onclick:stopPropagation="true">
                                <i class="bi bi-check-circle-fill"></i> Added
                            </button>
                        }
                        else
                        {
                            <button type="button" class="select-btn d-inline-flex align-items-center gap-1"
                                    @onclick="() => OnDrinkSelected.InvokeAsync(drink)" @onclick:stopPropagation="true">
                                <i class="bi bi-plus-circle"></i> Add
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="meal-card">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-1 fw-600">Fountain Drink</h5>
                <p class="text-muted mb-0" style="font-size: 0.9rem;">Included with your meal</p>
            </div>
            <div>
                <span class="status-badge complete d-inline-flex align-items-center justify-content-center">
                    <i class="bi bi-check"></i>
                </span>
            </div>
        </div>
    </div>
}
