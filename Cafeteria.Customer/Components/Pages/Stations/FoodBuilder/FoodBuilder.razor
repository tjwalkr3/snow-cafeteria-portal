@page "/station/{StationType}"
@page "/breakfast"
@page "/deli"
@page "/grill"
@page "/pizza"
@page "/wrap"
@rendermode InteractiveServer
@using Cafeteria.Customer.Components.Pages.Stations.Configuration
@using Cafeteria.Customer.Components.Pages.Stations.Panels.DrinkPanel
@using Cafeteria.Customer.Components.Pages.Stations.Panels.EntreePanel
@using Cafeteria.Customer.Components.Pages.Stations.Panels.SidePanel
@using Cafeteria.Customer.Components.Pages.Stations.TabNavigation.CardCategoryNav
@using Cafeteria.Customer.Components.Pages.Stations.TabNavigation.SwipeStepper
@using Cafeteria.Shared.DTOs
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>@(VM.Configuration?.PageTitle ?? "Station")</PageTitle>

@if (_isLoading)
{
    <div class="container px-3 py-4">
        <div class="text-center py-5">
            <Spinner Message="Loading menu..." />
        </div>
    </div>
}
else
{
    <div class="container py-2 px-1">
        <div class="mb-">
            <a href="@CreateBackUrl()" class="btn text-decoration-none ps-0">
                &#10094; Back to Station Selection
            </a>
        </div>

        @if (!VM.IsCardOrder)
        {
            <div class="swipe-info-banner d-flex align-items-start gap-2 my-3">
                <i class="bi bi-info-circle flex-shrink-0" style="margin-top: 2px;"></i>
                <span>Your meal swipe includes one entree, one side, and a drink. Follow the steps below to build your meal.</span>
            </div>
        }

        @if (VM.IsCardOrder)
        {
            <div class="card-info-banner d-flex align-items-start gap-2 my-3">
                <i class="bi bi-credit-card flex-shrink-0" style="margin-top: 2px;"></i>
                <span>Pay per item. Browse the categories below and add what you'd like to your cart.</span>
            </div>

            <CardCategoryNav Tabs="@(VM.Configuration?.Tabs ?? new())"
                             ActiveTab="@VM.ActiveTab"
                             HasSelectionForTab="@HasSelectionForTab"
                             GetSelectionText="@GetSelectionTextForTab"
                             GetTabIcon="@GetTabIcon"
                             OnTabSelected="@SetActiveTab" />
        }
        else
        {
            <SwipeStepper Tabs="@(VM.Configuration?.Tabs ?? new())"
                          ActiveTab="@VM.ActiveTab"
                          IsTabCompleted="@IsTabCompleted"
                          OnTabSelected="@SetActiveTab" />
        }

        <div class="content-area">
            @if (!VM.IsCardOrder)
            {
                <p class="step-hint text-muted mb-3">@GetStepHint()</p>
            }
            else
            {
                <p class="step-hint text-muted mb-3">@GetCardStepHint()</p>
            }

            @if (VM.ActiveTab == "entrees" && VM.Configuration?.ShowEntreeSelection == true)
            {
                <EntreePanel Entrees="@VM.Entrees"
                             SelectedEntree="@VM.State.SelectedEntree"
                             IsCardOrder="@VM.IsCardOrder"
                             SelectedBadges="@VM.State.SingleSelectOptions.Values.ToList()"
                             OnEntreeSelected="@SelectEntree" />
            }

            @if (VM.ActiveTab == "toppings" && VM.CurrentStationType == Configuration.StationType.Pizza)
            {
                var allToppings = VM.State.MultiSelectOptions.Values.SelectMany(v => v).ToList();
                <EntreePanel Entrees="@VM.Entrees"
                             SelectedEntree="@VM.State.SelectedEntree"
                             IsCardOrder="@VM.IsCardOrder"
                             SelectedBadges="@allToppings"
                             SelectionCount="@allToppings.Count"
                             RequiredCount="@(VM.Configuration?.MinimumToppingsRequired ?? 0)"
                             OnEntreeSelected="@SelectEntree" />
            }

            @if (VM.ActiveTab == "sandwich" && VM.CurrentStationType == Configuration.StationType.Deli)
            {
                var sandwichSelectionCount = VM.State.MultiSelectOptions.Values.Sum(list => list.Count);
                var sandwichComplete = IsBuilderEntreeComplete();
                var deliEntree = VM.Entrees.FirstOrDefault(e => e.EntreeName.Contains("Sandwich") || e.EntreeName.Contains("Deli"));
                var deliEntreeName = deliEntree?.EntreeName ?? "Sandwich";
                <div class="meal-card mb-3 d-flex justify-content-between align-items-center"
                     @onclick="OpenOptionsModal" style="cursor: pointer;">
                    <div class="d-flex align-items-center gap-3 flex-grow-1">
                        <div class="d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; background: #eef1f6; border-radius: 10px;">
                            <i class="bi bi-stack" style="font-size: 1.3rem; color: #1e366c;"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold" style="color: #1e366c;">@deliEntreeName</h5>
                            @if (sandwichSelectionCount > 0)
                            {
                                <div class="d-flex flex-wrap gap-1 mt-1">
                                    @foreach (var optionTypeWithOptions in VM.OptionTypes)
                                    {
                                        var selected = VM.GetSelectedOptionsForType(optionTypeWithOptions.OptionType.Id);
                                        @foreach (var opt in selected)
                                        {
                                            <span class="badge rounded-pill bg-light text-dark border" style="font-size: 0.75rem;">@opt</span>
                                        }
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted" style="font-size: 0.85rem;">Tap to build your sandwich</span>
                            }
                        </div>
                    </div>
                    <div class="ms-3 d-flex flex-column align-items-end gap-1">
                        @if (VM.IsCardOrder && deliEntree != null)
                        {
                            <span class="price-badge">$@deliEntree.EntreePrice.ToString("F2")</span>
                        }
                        @if (sandwichComplete)
                        {
                            <span class="select-btn added d-inline-flex align-items-center gap-1">
                                <i class="bi bi-check-circle-fill"></i> Added
                            </span>
                        }
                        else
                        {
                            <span class="status-badge pending d-inline-flex align-items-center justify-content-center">
                                @sandwichSelectionCount/@VM.OptionTypes.Sum(o => o.OptionType.NumIncluded)
                            </span>
                        }
                    </div>
                </div>
            }

            @if (VM.ActiveTab == "wrap" && VM.CurrentStationType == Configuration.StationType.Wraps)
            {
                var wrapSelectionCount = VM.State.MultiSelectOptions.Values.Sum(list => list.Count);
                var wrapComplete = IsBuilderEntreeComplete();
                var wrapEntree = VM.Entrees.FirstOrDefault(e => e.EntreeName.Contains("Wrap", StringComparison.OrdinalIgnoreCase));
                var wrapEntreeName = wrapEntree?.EntreeName ?? "Wrap";
                <div class="meal-card mb-3 d-flex justify-content-between align-items-center"
                     @onclick="OpenOptionsModal" style="cursor: pointer;">
                    <div class="d-flex align-items-center gap-3 flex-grow-1">
                        <div class="d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; background: #eef1f6; border-radius: 10px;">
                            <i class="bi bi-tornado" style="font-size: 1.3rem; color: #1e366c;"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold" style="color: #1e366c;">@wrapEntreeName</h5>
                            @if (wrapSelectionCount > 0)
                            {
                                <div class="d-flex flex-wrap gap-1 mt-1">
                                    @foreach (var optionTypeWithOptions in VM.OptionTypes)
                                    {
                                        var selected = VM.GetSelectedOptionsForType(optionTypeWithOptions.OptionType.Id);
                                        @foreach (var opt in selected)
                                        {
                                            <span class="badge rounded-pill bg-light text-dark border" style="font-size: 0.75rem;">@opt</span>
                                        }
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted" style="font-size: 0.85rem;">Tap to build your wrap</span>
                            }
                        </div>
                    </div>
                    <div class="ms-3 d-flex flex-column align-items-end gap-1">
                        @if (VM.IsCardOrder && wrapEntree != null)
                        {
                            <span class="price-badge">$@wrapEntree.EntreePrice.ToString("F2")</span>
                        }
                        @if (wrapComplete)
                        {
                            <span class="select-btn added d-inline-flex align-items-center gap-1">
                                <i class="bi bi-check-circle-fill"></i> Added
                            </span>
                        }
                        else
                        {
                            <span class="status-badge pending d-inline-flex align-items-center justify-content-center">
                                @wrapSelectionCount/@VM.OptionTypes.Sum(o => o.OptionType.NumIncluded)
                            </span>
                        }
                    </div>
                </div>
            }

            @if (VM.ActiveTab == "sides")
            {
                <SidePanel Sides="@VM.Sides"
                           SelectedSide="@VM.State.SelectedSide"
                           IsCardOrder="@VM.IsCardOrder"
                           OnSideSelected="@SelectSide" />
            }

            @if (VM.ActiveTab == "drinks")
            {
                <DrinkPanel Drinks="@VM.Drinks"
                            SelectedDrink="@VM.State.SelectedDrink"
                            IsCardOrder="@VM.IsCardOrder"
                            OnDrinkSelected="@SelectDrink" />
            }
        </div>

        @if (StagingStore.IsModalOpen && VM.OptionTypes.Any())
        {
            <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
                    <div class="modal-content border-0 shadow" style="border-radius: 16px;">
                        <div class="modal-header border-0 pb-0">
                            <h5 class="modal-title fw-bold" style="color: #1e366c;">@StagingStore.ModalTitle</h5>
                            <button type="button" class="btn-close" @onclick="DiscardOptions"></button>
                        </div>
                        <div class="modal-body pt-2">
                            @{ var optTypeList = VM.OptionTypes.ToList(); }
                            @for (int oi = 0; oi < optTypeList.Count; oi++)
                            {
                                var optionTypeWithOptions = optTypeList[oi];
                                var optType = optionTypeWithOptions.OptionType;
                                var isMulti = VM.IsMultiSelectOptionType(optionTypeWithOptions);
                                var stagedForType = StagingStore.StagedSelections.GetValueOrDefault(optType.Id) ?? new HashSet<string>();
                                var stagedCount = stagedForType.Count;
                                var extraCost = stagedCount > optType.NumIncluded ?
                                    (stagedCount - optType.NumIncluded) * optType.FoodOptionPrice : 0;
                                var isLast = oi == optTypeList.Count - 1;

                                <div class="@(isLast ? "mb-2" : "mb-4 pb-3")" style="@(isLast ? "" : "border-bottom: 1px solid #e9ecef;")">
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <i class="bi @GetCategoryIcon(optType.FoodOptionTypeName)" style="font-size: 1.1rem; color: #1e366c;"></i>
                                        <span style="font-size: 1rem; font-weight: 700; color: #1e366c;">@optType.FoodOptionTypeName</span>
                                        <span class="text-muted" style="font-size: 0.8rem; font-weight: 400;">
                                            — @(isMulti ? $"Select {optType.NumIncluded}" : "Select 1")
                                        </span>
                                        @if (VM.IsCardOrder && optType.FoodOptionPrice > 0 && optType.MaxAmount > optType.NumIncluded)
                                        {
                                            <span class="text-danger" style="font-size: 0.8rem; font-weight: 500;">+$@optType.FoodOptionPrice.ToString("F2") each extra</span>
                                        }
                                    </div>
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var option in optionTypeWithOptions.Options)
                                        {
                                            var optTypeId = optType.Id;
                                            var isStaged = stagedForType.Contains(option.FoodOptionName);

                                            @if (isMulti)
                                            {
                                                <button type="button" class="option-chip @(isStaged ? "selected" : "") d-inline-flex align-items-center"
                                                    @onclick="() => ToggleStagedOption(optTypeId, option.FoodOptionName)">
                                                    @option.FoodOptionName
                                                    @if (isStaged)
                                                    {
                                                        <i class="bi bi-check-lg"></i>
                                                    }
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button" class="option-chip @(isStaged ? "selected" : "") d-inline-flex align-items-center"
                                                    @onclick="() => SetStagedOption(optTypeId, option.FoodOptionName)">
                                                    @option.FoodOptionName
                                                    @if (isStaged)
                                                    {
                                                        <i class="bi bi-check-lg"></i>
                                                    }
                                                </button>
                                            }
                                        }
                                    </div>
                                    @if (VM.IsCardOrder && extraCost > 0)
                                    {
                                        <div class="info-banner warning mt-2">
                                            <div>
                                                <i class="bi bi-exclamation-triangle me-2"></i>
                                                +$@extraCost.ToString("F2") for @(stagedCount - optType.NumIncluded)
                                                extra @optType.FoodOptionTypeName.ToLower()
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        <div class="modal-footer border-0 pt-0">
                            <button type="button" class="btn btn-primary w-100" style="background: #1e366c; border-color: #1e366c; border-radius: 10px; padding: 0.75rem;" @onclick="ConfirmOptions">
                                Done
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="container footer-bar bg-white border-top shadow-sm d-flex justify-content-end align-items-center px-4 py-3">
           
            <div class="d-flex gap-2">
                @if (VM.IsCardOrder)
                {
                    <button type="button" class="btn btn-primary" disabled="@(!HasAnySelection())" @onclick="AddToOrder">
                        Add to Cart
                    </button>
                }
                else
                {
                    @if (!IsFirstTab())
                    {
                        <button type="button" class="btn btn-outline-secondary" @onclick="GoToPreviousTab">
                            <i class="bi bi-chevron-left me-1"></i> Back
                        </button>
                    }
                    @if (IsLastTab())
                    {
                        <button type="button" class="btn btn-primary" disabled="@(!AreAllTabsCompleted())" @onclick="AddToOrder">
                            Add to Order
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-primary" disabled="@(!IsTabCompleted(VM.ActiveTab))"
                            @onclick="GoToNextTab">
                            Next <i class="bi bi-chevron-right ms-1"></i>
                        </button>
                    }
                }
            </div>
        </div>
    </div>
}
