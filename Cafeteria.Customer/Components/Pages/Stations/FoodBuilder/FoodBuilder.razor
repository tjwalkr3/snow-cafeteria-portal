@page "/station"
@rendermode InteractiveServer
@using Cafeteria.Customer.Components.Pages.Stations.Footer
@using Cafeteria.Customer.Components.Pages.Stations.OptionsModal
@using Cafeteria.Customer.Components.Pages.Stations.Panels.DrinkPanel
@using Cafeteria.Customer.Components.Pages.Stations.Panels.EntreePanel
@using Cafeteria.Customer.Components.Pages.Stations.Panels.SidePanel
@using Cafeteria.Customer.Components.Pages.Stations.TabNavigation.CardCategoryNav
@using Cafeteria.Customer.Components.Pages.Stations.TabNavigation.SwipeStepper
@using Cafeteria.Shared.DTOs
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>@PageTitle</PageTitle>

@if (_isLoading)
{
    <div class="container px-3 py-4">
        <div class="text-center py-5">
            <Spinner Message="Loading menu..." />
        </div>
    </div>
}
else
{
    <div class="container px-1 builder-shell">
        <div class="builder-top">
            <div>
                <a href="@CreateBackUrl()" class="btn text-decoration-none ps-0">
                    &#10094; Back to Station Selection
                </a>
            </div>

            @if (!IsCardOrder)
            {
                <div class="swipe-info-banner d-flex align-items-start gap-2 my-3">
                    <i class="bi bi-info-circle flex-shrink-0" style="margin-top: 2px;"></i>
                    <span>Your meal swipe includes one entree, one side, and a drink. Follow the steps below to build your meal.</span>
                </div>
            }

            @if (IsCardOrder)
            {
                <div class="card-info-banner d-flex align-items-start gap-2 my-3">
                    <i class="bi bi-credit-card flex-shrink-0" style="margin-top: 2px;"></i>
                    <span>Pay per item. Browse the categories below and add what you'd like to your cart.</span>
                </div>

                <CardCategoryNav Tabs="@Tabs"
                                 ActiveTab="@ActiveTab"
                                 HasSelectionForTab="@HasSelectionForTab"
                                 GetSelectionText="@GetSelectionTextForTab"
                                 GetTabIcon="@GetTabIcon"
                                 OnTabSelected="@SetActiveTab" />
            }
            else
            {
                <SwipeStepper Tabs="@Tabs"
                              ActiveTab="@ActiveTab"
                              IsTabCompleted="@IsTabCompleted"
                              OnTabSelected="@SetActiveTab" />
            }

            @if (!IsCardOrder)
            {
                <p class="step-hint text-muted mt-4 mb-0">@GetStepHint()</p>
            }
            else
            {
                <p class="step-hint text-muted mt-4 mb-0">@GetCardStepHint()</p>
            }
        </div>

        <div class="content-area @(IsCardOrder ? "card-tab-panel" : "")">

            @if (ActiveTab == "entrees")
            {
                var allSelections = State.SingleSelectOptions.Values
                    .Concat(State.MultiSelectOptions.Values.SelectMany(v => v)).ToList();
                <EntreePanel Entrees="@Entrees"
                             SelectedEntree="@State.SelectedEntree"
                             IsCardOrder="@IsCardOrder"
                             SelectedBadges="@allSelections"
                             Quantity="@_entreeQuantity"
                             CardQuantities="@_cardEntreeQtys"
                             OnQuantityChanged="@ChangeEntreeQuantity"
                             OnCardQtyChanged="@((args) => ChangeCardEntreeQty(args.Item1, args.Item2))"
                             OnEntreeSelected="@SelectEntree" />
            }

            @if (ActiveTab == "sides")
            {
                <SidePanel Sides="@Sides"
                           SelectedSide="@State.SelectedSide"
                           IsCardOrder="@IsCardOrder"
                           Quantity="@_sideQuantity"
                           CardQuantities="@_cardSideQtys"
                           OnQuantityChanged="@ChangeSideQuantity"
                           OnCardQtyChanged="@((args) => ChangeCardSideQty(args.Item1, args.Item2))"
                           OnSideSelected="@SelectSide"
                           OnSideWithOptionsSelected="@SelectSideWithOptions" />
            }

            @if (ActiveTab == "drinks")
            {
                <DrinkPanel Drinks="@Drinks"
                            SelectedDrink="@State.SelectedDrink"
                            IsCardOrder="@IsCardOrder"
                            Quantity="@_drinkQuantity"
                            CardQuantities="@_cardDrinkQtys"
                            OnQuantityChanged="@ChangeDrinkQuantity"
                            OnCardQtyChanged="@((args) => ChangeCardDrinkQty(args.Item1, args.Item2))"
                            OnDrinkSelected="@SelectDrink" />
            }
        </div>

        @{
            var activeOptionTypes = StagingStore.StagedSide?.OptionTypes ?? OptionTypes;
        }
        @if (StagingStore.IsModalOpen && activeOptionTypes.Any())
        {
            <OptionsModal OptionTypes="@activeOptionTypes"
                          IsCardOrder="@IsCardOrder"
                          StagingStore="@StagingStore"
                          OnConfirm="@ConfirmOptions"
                          OnCancel="@DiscardOptions" />
        }

        <Footer IsCardOrder="@IsCardOrder"
                           IsFirstTab="@IsFirstTab()"
                           IsLastTab="@IsLastTab()"
                           CanGoNext="@IsTabCompleted(ActiveTab)"
                           CanAddToOrder="@(IsCardOrder ? HasAnySelection() : AreAllTabsCompleted())"
                           OnAddToOrder="@AddToOrder"
                           OnNext="@GoToNextTab"
                           OnPrevious="@GoToPreviousTab" />
    </div>
}
