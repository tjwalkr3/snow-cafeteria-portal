<div class="container footer-bar bg-white border-top shadow-sm d-flex justify-content-end align-items-center px-4 py-3">
    <div class="d-flex gap-2">
        @if (IsCardOrder)
        {
            <button type="button" class="btn btn-primary" disabled="@(!CanAddToOrder)" @onclick="OnAddToOrder">
                Go to Cart
            </button>
        }
        else
        {
            @if (!IsFirstTab)
            {
                <button type="button" class="btn btn-outline-secondary" @onclick="OnPrevious">
                    <i class="bi bi-chevron-left me-1"></i> Back
                </button>
            }
            @if (IsLastTab)
            {
                <button type="button" class="btn btn-primary" disabled="@(!CanAddToOrder)" @onclick="OnAddToOrder">
                    Add to Order
                </button>
            }
            else
            {
                <button type="button" class="btn btn-primary" disabled="@(!CanGoNext)" @onclick="OnNext">
                    Next <i class="bi bi-chevron-right ms-1"></i>
                </button>
            }
        }
    </div>
</div>
