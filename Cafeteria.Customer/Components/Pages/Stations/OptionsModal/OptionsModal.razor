@using Cafeteria.Shared.DTOs.Menu

<div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
        <div class="modal-content border-0 shadow" style="border-radius: 16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" style="color: #1e366c;">@StagingStore.ModalTitle</h5>
                <button type="button" class="btn-close" @onclick="OnCancel"></button>
            </div>
            <div class="modal-body pt-2">
                @{ var optTypeList = OptionTypes; }
                @for (int oi = 0; oi < optTypeList.Count; oi++)
                {
                    var optionTypeWithOptions = optTypeList[oi];
                    var optType = optionTypeWithOptions.OptionType;
                    var isMulti = optType.MaxAmount > 1;
                    var stagedForType = StagingStore.StagedSelections.GetValueOrDefault(optType.Id) ?? new HashSet<string>();
                    var stagedCount = stagedForType.Count;
                    var extraCost = stagedCount > optType.IncludedAmount
                        ? (stagedCount - optType.IncludedAmount) * optType.FoodOptionPrice
                        : 0;
                    var isComplete = IsOptionTypeComplete(optionTypeWithOptions, stagedCount);
                    var isLast = oi == optTypeList.Count - 1;

                    <div class="@(isLast ? "mb-2" : "mb-4 pb-3")" style="@(isLast ? "" : "border-bottom: 1px solid #e9ecef;")">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi @(optType.IconBootstrapName ?? "bi-circle")" style="font-size: 1.1rem; color: #1e366c;"></i>
                            <span style="font-size: 1rem; font-weight: 700; color: #1e366c;">@optType.FoodOptionTypeName</span>
                            <span class="text-muted" style="font-size: 0.8rem; font-weight: 400;">
                                @GetHintText(optType, isMulti)
                            </span>
                            @if (IsCardOrder && optType.FoodOptionPrice > 0 && optType.MaxAmount > optType.IncludedAmount)
                            {
                                <span class="text-danger" style="font-size: 0.8rem; font-weight: 500;">+$@optType.FoodOptionPrice.ToString("F2") each extra</span>
                            }
                            @if (isMulti && optType.RequiredAmount > 0)
                            {
                                <span class="badge @(isComplete ? "bg-success" : "bg-danger")" style="font-size: 0.75rem;">
                                    @stagedCount / @optType.RequiredAmount
                                </span>
                            }
                            else if (!isMulti && optType.RequiredAmount > 0)
                            {
                                @if (isComplete)
                                {
                                    <i class="bi bi-check-circle-fill text-success" style="font-size: 0.9rem;"></i>
                                }
                                else
                                {
                                    <i class="bi bi-exclamation-circle-fill text-danger" style="font-size: 0.9rem;"></i>
                                }
                            }
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var option in optionTypeWithOptions.Options)
                            {
                                var optTypeId = optType.Id;
                                var isStaged = stagedForType.Contains(option.FoodOptionName);

                                @if (isMulti)
                                {
                                    <button type="button" class="option-chip @(isStaged ? "selected" : "") d-inline-flex align-items-center"
                                            @onclick="() => Toggle(optTypeId, option.FoodOptionName)">
                                        @option.FoodOptionName
                                        @if (isStaged)
                                        {
                                            <i class="bi bi-check-lg"></i>
                                        }
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="option-chip @(isStaged ? "selected" : "") d-inline-flex align-items-center"
                                            @onclick="() => Set(optTypeId, option.FoodOptionName)">
                                        @option.FoodOptionName
                                        @if (isStaged)
                                        {
                                            <i class="bi bi-check-lg"></i>
                                        }
                                    </button>
                                }
                            }
                        </div>
                        @if (IsCardOrder && extraCost > 0)
                        {
                            <div class="info-banner warning mt-2">
                                <div>
                                    <i class="bi bi-exclamation-triangle me-2"></i>
                                    +$@extraCost.ToString("F2") for @(stagedCount - optType.IncludedAmount)
                                    extra @optType.FoodOptionTypeName.ToLower()
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-primary w-100"
                        style="background: @(IsAllComplete ? "#1e366c" : "#6c757d"); border-color: @(IsAllComplete ? "#1e366c" : "#6c757d"); border-radius: 10px; padding: 0.75rem;"
                        disabled="@(!IsAllComplete)"
                        @onclick="OnConfirm">
                    Done
                </button>
            </div>
        </div>
    </div>
</div>
