@page "/thank-you"
@rendermode InteractiveServer

<PageTitle>Thank You</PageTitle>

<div class="thankyou-wrapper text-center">
    <div class="text-center">
        <h1 class="thankyou-title mb-2">Thank You for Your Order!</h1>
        <p class="thankyou-subtitle mb-5">Your order has been placed successfully.<br />It should be ready in about <strong>5–10 minutes</strong>.</p>
        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
            <a href="/" class="thankyou-btn-primary">
                <i class="bi bi-plus-circle me-2"></i>Place Another Order
            </a>
            <a href="/order-history" class="thankyou-btn-secondary">
                <i class="bi bi-clock-history me-2"></i>View Order History
            </a>
        </div>
    </div>
</div>
