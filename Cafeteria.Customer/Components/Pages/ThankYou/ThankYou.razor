@page "/thank-you"
@rendermode InteractiveServer

<PageTitle>Thank You</PageTitle>

<div class="container px-3 py-2">
    <div class="empty-state text-center mx-auto my-5">
        <h1 class="order-title mb-3">Thank You for Your Order!</h1>
        <p class="order-subtitle mb-4">It should be ready in about 5-10 minutes.</p>
        <a href="/" class="btn btn-primary">Place Another Order</a>
        <a href="/order-history" class="btn btn-outline-secondary ms-2">View Order History</a>
    </div>
</div>