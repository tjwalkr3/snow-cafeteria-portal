@page "/place-order"
@rendermode InteractiveServer
@using Cafeteria.Shared.DTOs
@using Cafeteria.Customer.Components.Pages

<PageTitle>Review Your Order</PageTitle>

<ConfirmationToast IsVisible="@_showToast" Title="Order Placed!" Message="@_toastMessage" OnHidden="@OnToastHidden" />

@if (!IsInitialized || _isLoading)
{
    <div class="loading-container">
        <Spinner Message="Loading your order..." />
    </div>
}
else if (IsInitialized && PlaceOrderVM.ErrorOccurred())
{
    Navigation.NavigateTo("/error", false);
}
else if (Order == null || (!Order.Entrees.Any() && !Order.Sides.Any() && !Order.Drinks.Any()))
{
    <div class="container px-3 py-4">
        <div class="empty-state">
            <h4>Your Order is Empty</h4>
            <p>You haven't added any items yet. Start building your order!</p>
            <a href="/" class="btn btn-primary">Start an Order</a>
        </div>
    </div>
}
else
{
    <div class="container px-3 py-4">
        <div class="mb-3">
            <a href="@GetStationSelectUrl()" class="btn text-decoration-none ps-0 back-button">
                ❮ Continue Shopping
            </a>
        </div>

        <div class="order-header">
            <h1 class="order-title">Your Order</h1>
            <p class="order-subtitle">Review your items before placing your order</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="items-summary">
                    <div class="items-count">
                        @if (Order.IsCardOrder)
                        {
                            <text>ITEMS <span>@GetTotalItemCount()</span></text>
                        }
                        else
                        {
                            <text>SWIPES <span>@GetTotalItemCount()</span></text>
                        }
                    </div>
                    <div class="est-time">
                        EST. MINUTES <span>15-20</span>
                    </div>
                </div>

                @if (Order.IsCardOrder)
                {
                    @foreach (var entreeGroup in EntreeGroups)
                    {
                        <div class="order-item">
                            <div class="item-header">
                                <div class="item-info">
                                    <div class="item-name">@entreeGroup.Entree.Entree.EntreeName</div>
                                    <div class="item-description">
                                        @if (entreeGroup.Entree.SelectedOptions.Any())
                                        {
                                            @string.Join(", ", entreeGroup.Entree.SelectedOptions.Select(o => o.Option.FoodOptionName))
                                        }
                                        else
                                        {
                                            <text>Our classic @entreeGroup.Entree.Entree.EntreeName.ToLower()</text>
                                        }
                                    </div>
                                </div>
                                <div class="item-price">$@GetItemPrice(entreeGroup.Entree).ToString("F2")</div>
                            </div>

                            <div class="item-controls">
                                <div class="quantity-controls">
                                    <button class="qty-btn" @onclick="() => RemoveEntreeItem(entreeGroup)">−</button>
                                    <span class="qty-display">Qty: @entreeGroup.Quantity</span>
                                    <button class="qty-btn" @onclick="() => AddEntreeItem(entreeGroup)">+</button>
                                </div>
                                <button class="remove-btn" @onclick="() => RemoveEntreeItem(entreeGroup)">Remove</button>
                            </div>
                        </div>
                    }

                    @foreach (var sideGroup in SideGroups)
                    {
                        <div class="order-item">
                            <div class="item-header">
                                <div class="item-info">
                                    <div class="item-name">@sideGroup.Side.Side.SideName</div>
                                    <div class="item-description">
                                        @if (sideGroup.Side.SelectedOptions.Any())
                                        {
                                            @string.Join(", ", sideGroup.Side.SelectedOptions.Select(o => o.Option.FoodOptionName))
                                        }
                                        else
                                        {
                                            <text>Fresh @sideGroup.Side.Side.SideName.ToLower()</text>
                                        }
                                    </div>
                                </div>
                                <div class="item-price">$@GetItemPrice(sideGroup.Side).ToString("F2")</div>
                            </div>

                            <div class="item-controls">
                                <div class="quantity-controls">
                                    <button class="qty-btn" @onclick="() => RemoveSideItem(sideGroup)">−</button>
                                    <span class="qty-display">Qty: @sideGroup.Quantity</span>
                                    <button class="qty-btn" @onclick="() => AddSideItem(sideGroup)">+</button>
                                </div>
                                <button class="remove-btn" @onclick="() => RemoveSideItem(sideGroup)">Remove</button>
                            </div>
                        </div>
                    }

                    @foreach (var drinkGroup in DrinkGroups)
                    {
                        <div class="order-item">
                            <div class="item-header">
                                <div class="item-info">
                                    <div class="item-name">@drinkGroup.Drink.DrinkName</div>
                                    <div class="item-description">Refreshing beverage</div>
                                </div>
                                <div class="item-price">$@drinkGroup.Drink.DrinkPrice.ToString("F2")</div>
                            </div>

                            <div class="item-controls">
                                <div class="quantity-controls">
                                    <button class="qty-btn" @onclick="() => RemoveDrinkItem(drinkGroup)">−</button>
                                    <span class="qty-display">Qty: @drinkGroup.Quantity</span>
                                    <button class="qty-btn" @onclick="() => AddDrinkItem(drinkGroup)">+</button>
                                </div>
                                <button class="remove-btn" @onclick="() => RemoveDrinkItem(drinkGroup)">Remove</button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    @foreach (var swipe in SwipeGroups)
                    {
                        <div class="order-item swipe-item">
                            <div class="swipe-details">
                                <div class="swipe-row">
                                    <span class="swipe-label swipe-label--entree">Entree</span>
                                    <span class="swipe-value">@swipe.Entree.Entree.EntreeName</span>
                                </div>
                                @if (swipe.Entree.SelectedOptions.Any())
                                {
                                    <div class="swipe-options">
                                        @foreach (var opt in swipe.Entree.SelectedOptions)
                                        {
                                            <span class="option-badge">@opt.Option.FoodOptionName</span>
                                        }
                                    </div>
                                }
                                <div class="swipe-row">
                                    <span class="swipe-label swipe-label--side">Side</span>
                                    <span class="swipe-value">@swipe.Side.Side.SideName</span>
                                    @foreach (var opt in swipe.Side.SelectedOptions)
                                    {
                                        <span class="option-badge">@opt.Option.FoodOptionName</span>
                                    }
                                    <span class="swipe-separator">|</span>
                                    <span class="swipe-label swipe-label--drink">Drink</span>
                                    <span class="swipe-value">@swipe.Drink.DrinkName</span>
                                </div>
                            </div>

                            <div class="item-controls">
                                <div class="quantity-controls">
                                    <button class="qty-btn" @onclick="() => DecreaseSwipeQuantity(swipe)">−</button>
                                    <span class="qty-display">Qty: @swipe.Quantity</span>
                                    <button class="qty-btn" @onclick="() => IncreaseSwipeQuantity(swipe)">+</button>
                                </div>
                                <button class="remove-btn" @onclick="() => RemoveSwipeGroup(swipe)">Remove</button>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="col-lg-4">
                <div class="order-summary-card">
                    @if (Order.IsCardOrder)
                    {
                        <div class="summary-row">
                            <span class="summary-label">Subtotal:</span>
                            <span class="summary-value">$@Price.ToString("F2")</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-label">Tax (7.75%):</span>
                            <span class="summary-value">$@((Price * 0.0775m).ToString("F2"))</span>
                        </div>
                        <hr class="summary-divider" />
                        <div class="total-row">
                            <span class="total-label">Total:</span>
                            <span class="total-value">$@((Price * 1.0775m).ToString("F2"))</span>
                        </div>
                    }
                    else
                    {
                        <div class="summary-row">
                            <span class="summary-label">Subtotal:</span>
                            <span class="summary-value">@GetTotalSwipeCount() Swipe@(GetTotalSwipeCount() > 1 ? "s" : "")</span>
                        </div>
                        <hr class="summary-divider" />
                        <div class="total-row">
                            <span class="total-label">Total:</span>
                            <span class="total-value">@GetTotalSwipeCount() Swipe@(GetTotalSwipeCount() > 1 ? "s" : "")</span>
                        </div>
                    }

                    <div class="action-buttons">
                        <button @onclick="HandlePlaceOrder" class="place-order-btn">Place Order</button>
                        <a href="@GetStationSelectUrl()" class="continue-shopping-btn">❮ Continue Shopping</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}