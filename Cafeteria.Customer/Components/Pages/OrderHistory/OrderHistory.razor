@page "/order-history"
@rendermode InteractiveServer
@using Cafeteria.Shared.DTOs.Order
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>My Order History</PageTitle>

@if (!IsInitialized || OrderHistoryVM.IsLoading)
{
    <div class="loading-container d-flex justify-content-center align-items-center">
        <Spinner Message="Loading your orders..." />
    </div>
}
else
{
    <div class="container px-4 py-4">
        <div class="mb-3">
            <a href="/" class="back-link d-inline-flex align-items-center gap-2">
                <i class="bi bi-arrow-left"></i> Back to Menu
            </a>
        </div>

        <div class="page-header mb-3">
            <h1 class="page-title">My Order History</h1>
            <p class="page-subtitle">View your past cafeteria orders</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-5 col-xl-4">
                <div class="orders-list d-flex flex-column gap-3">
                    @if (OrderHistoryVM.Orders == null || !OrderHistoryVM.Orders.Any())
                    {
                        <div class="empty-orders">
                            <p>No orders found.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var order in OrderHistoryVM.Orders)
                        {
                            <div class="order-card @(OrderHistoryVM.SelectedOrder?.Id == order.Id ? "selected" : "") p-3"
                                 @onclick="() => SelectOrder(order)">
                                <div class="order-card-header d-flex align-items-center gap-2 mb-2">
                                    @if (OrderHistoryVM.SelectedOrder?.Id == order.Id)
                                    {
                                        <span class="status-indicator"></span>
                                    }
                                    <span class="order-number flex-grow-1">Order #@order.Id</span>
                                    <i class="bi bi-chevron-right"></i>
                                </div>
                                <div class="order-card-details d-flex flex-column gap-1 mb-3">
                                    <span class="order-date">@order.OrderTime.ToString("MMM dd, yyyy") · @order.OrderTime.ToString("h:mm tt")</span>
                                    <span class="order-summary">
                                        @OrderHistoryVM.GetItemCount(order) item@(OrderHistoryVM.GetItemCount(order) != 1 ? "s" : "") ·
                                        @if (OrderHistoryVM.IsCardPayment(order))
                                        {
                                            <text>$@OrderHistoryVM.GetTotal(order).ToString("F2")</text>
                                        }
                                        else
                                        {
                                            <text>@OrderHistoryVM.GetSwipeCount(order) swipe@(OrderHistoryVM.GetSwipeCount(order) != 1 ? "s" : "")</text>
                                        }
                                    </span>
                                </div>
                                <div class="order-card-badge d-flex">
                                    @if (OrderHistoryVM.IsCardPayment(order))
                                    {
                                        <span class="badge payment-badge card-badge">Card Payment</span>
                                    }
                                    else
                                    {
                                        <span class="badge payment-badge swipe-badge">Meal Swipe</span>
                                    }
                                </div>
                            </div>
                        }
                    }

                    @if (OrderHistoryVM.HasMoreOrders)
                    {
                        <div class="load-more-container d-flex justify-content-center p-3">
                            <button class="btn btn-link load-more-btn d-inline-flex align-items-center gap-2" @onclick="LoadMore">
                                <i class="bi bi-clock-history"></i> Load More Orders
                            </button>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-7 col-xl-8">
                @if (OrderHistoryVM.SelectedOrder != null)
                {
                    var selectedOrder = OrderHistoryVM.SelectedOrder;
                    <div class="order-details-card p-3">
                        <div class="order-details-header d-flex justify-content-between align-items-start mb-3 pb-3 border-bottom">
                            <div>
                                <h2 class="order-details-title">Order #@selectedOrder.Id</h2>
                                <span class="order-details-date">@selectedOrder.OrderTime.ToString("MMMM dd, yyyy") · @selectedOrder.OrderTime.ToString("h:mm tt")</span>
                            </div>
                            @if (OrderHistoryVM.IsCardPayment(selectedOrder))
                            {
                                <span class="badge payment-badge-lg card-badge-lg d-inline-flex align-items-center gap-2">
                                    <i class="bi bi-credit-card"></i> Card Payment
                                </span>
                            }
                            else
                            {
                                <span class="badge payment-badge-lg swipe-badge-lg d-inline-flex align-items-center gap-2">
                                    <i class="bi bi-wallet2"></i> Meal Swipe
                                </span>
                            }
                        </div>

                        <div class="order-items-section">
                            <h3 class="items-heading">ITEMS</h3>

                            @foreach (var item in selectedOrder.FoodItems)
                            {
                                <div class="order-item-card">
                                    <div class="order-item-header d-flex justify-content-between align-items-start">
                                        <div class="order-item-info flex-grow-1">
                                            <h4 class="order-item-name">@item.Name</h4>
                                            <span class="order-item-station d-inline-flex align-items-center gap-1">
                                                <i class="bi bi-geo-alt"></i> @OrderHistoryVM.GetStationName(item.StationId)
                                            </span>
                                        </div>
                                        @if (OrderHistoryVM.IsCardPayment(selectedOrder) && item.CardCost.HasValue)
                                        {
                                            <span class="order-item-price">$@item.CardCost.Value.ToString("F2")</span>
                                        }
                                    </div>
                                    @if (item.Options.Any())
                                    {
                                        <div class="order-item-options d-flex flex-wrap gap-2 mt-3">
                                            @foreach (var option in item.Options)
                                            {
                                                <span class="option-badge">@option.FoodOptionName</span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <div class="order-totals-section">
                            @if (OrderHistoryVM.IsCardPayment(selectedOrder))
                            {
                                <div class="totals-row d-flex justify-content-between py-2">
                                    <span class="totals-label">Subtotal</span>
                                    <span class="totals-value">$@OrderHistoryVM.GetSubtotal(selectedOrder).ToString("F2")</span>
                                </div>
                                <div class="totals-row d-flex justify-content-between py-2">
                                    <span class="totals-label">Tax (7.75%)</span>
                                    <span class="totals-value">$@OrderHistoryVM.GetTax(selectedOrder).ToString("F2")</span>
                                </div>
                                <div class="totals-row total-final d-flex justify-content-between">
                                    <span class="totals-label">Total</span>
                                    <span class="totals-value total-amount">$@OrderHistoryVM.GetTotal(selectedOrder).ToString("F2")</span>
                                </div>
                            }
                            else
                            {
                                <div class="totals-row total-final d-flex justify-content-between">
                                    <span class="totals-label">Total</span>
                                    <span class="totals-value total-amount">@OrderHistoryVM.GetSwipeCount(selectedOrder) Swipe@(OrderHistoryVM.GetSwipeCount(selectedOrder) != 1 ? "s" : "")</span>
                                </div>
                            }
                        </div>

                        <div class="order-actions d-flex flex-column flex-lg-row gap-3">
                            <button class="btn btn-outline-primary action-btn flex-grow-1 d-inline-flex align-items-center justify-content-center gap-2">
                                <i class="bi bi-printer"></i> Print Receipt
                            </button>
                            <button class="btn btn-primary action-btn reorder-btn flex-grow-1 d-inline-flex align-items-center justify-content-center gap-2">
                                <i class="bi bi-arrow-repeat"></i> Reorder Items
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="no-order-selected text-center">
                        <i class="bi bi-receipt d-block mb-3"></i>
                        <p>Select an order to view details</p>
                    </div>
                }
            </div>
        </div>
    </div>
}