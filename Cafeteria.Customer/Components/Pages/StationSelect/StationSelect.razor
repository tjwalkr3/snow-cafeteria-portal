@page "/station-select"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Select Station</PageTitle>

<div class="container py-2 px-1">
    @if (StationSelectVM.Stations == null && IsInitialized == false)
    {
        <div class="text-center py-5">
            <Spinner Message="Loading stations..." />
        </div>
    }
    else if (IsInitialized == true && StationSelectVM.ErrorOccurredWhileParsingSelectedLocation())
    {
        Navigation.NavigateTo("/error", false);
    }
    else if (StationSelectVM.Stations != null && StationSelectVM.Stations.Count == 0)
    {
        <a href="@CreateBackUrl()" class="btn text-decoration-none ps-0">
            ❮ Back to Location
        </a>

        <div class="text-center py-5">
            <h2 class="mb-3">No Stations Currently Open</h2>
            <p class="fs-6">All stations are currently closed. Please try again later.</p>
        </div>
    }
    else if (StationSelectVM.Stations != null)
    {
        <a href="@CreateBackUrl()" class="btn text-decoration-none ps-0">
            ❮ Back to Location
        </a>

        <div class="text-center mb-5">
            <h1 class="station-title mb-2 fs-2 fw-bold">Select Your Station</h1>
            <p class="station-subtitle fs-6 mb-0">Please choose your preferred dining station to continue</p>
        </div>

        <div class="row row-cols-1 row-cols-md-2 g-4 justify-content-center">
            @foreach (var station in StationSelectVM.Stations)
            {
                <div class="col">
                    <button class="card-link text-decoration-none d-block w-100 p-0 border-0 bg-transparent"
                            @onclick="() => HandleStationSelected(station.Id)">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="card-body text-center p-4">
                                <div class="mb-4">
                                    <div class="icon-circle">
                                        <i class="bi @(station.IconName ?? "bi-shop") fs-2"></i>
                                    </div>
                                </div>
                                <h3 class="card-title station-card-title mb-3 fs-4 fw-bold">@station.StationName</h3>
                                <p class="station-card-description mb-0 fs-6">@station.StationDescription
                                </p>
                            </div>
                        </div>
                    </button>
                </div>
            }
        </div>
    }
</div>
