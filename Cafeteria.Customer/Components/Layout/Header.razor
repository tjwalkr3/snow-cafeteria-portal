<header class="header py-3">
    <div class="header-content px-4">
        <div class="d-flex align-items-center">
            <a href="/" class="brand-text fs-2 fw-semibold text-decoration-none">Snow Cafeteria</a>
        </div>
        <nav class="d-flex align-items-center gap-3">
            <button class="btn btn-link text-white position-relative p-1 text-decoration-none"
                title="Order History"
                @onclick="NavigateToOrderHistory">
                <span class="bi bi-clock-history fs-5"></span>
            </button>
            <button class="btn btn-link text-white position-relative p-1 text-decoration-none"
                title="Cart"
                @onclick="NavigateToCart">
                <span class="bi bi-cart3 fs-5"></span>
                @if (cartItemCount > 0)
                {
                    <span class="position-absolute translate-middle badge rounded-pill bg-danger"
                        style="top: 5px; left: 85%;">
                        @cartItemCount
                    </span>
                }
            </button>
            <button class="btn btn-link text-white position-relative p-1 text-decoration-none"
                title="User Profile"
                @onclick="NavigateToUserProfile">
                <span class="bi bi-person-circle fs-5"></span>
            </button>
            <SigninButton />
        </nav>
    </div>
</header>

@using Cafeteria.Customer.Components.Layout.SigninButton
@using Cafeteria.Customer.Services
@using Cafeteria.Customer.Services.Cart
@using Microsoft.AspNetCore.Components.Routing
@implements IDisposable
@rendermode InteractiveServer
@inject ICartService CartService
@inject NavigationManager NavigationManager
@inject CartNotificationService CartNotification

@code {
    private int cartItemCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadCartCount();
        NavigationManager.LocationChanged += OnLocationChanged;
        CartNotification.OnCartChanged += OnCartChanged;
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await LoadCartCount();
        await InvokeAsync(StateHasChanged);
    }

    private async void OnCartChanged()
    {
        await LoadCartCount();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadCartCount()
    {
        var order = await CartService.GetOrder("order");
        if (order != null)
        {
            if (!order.IsCardOrder)
            {
                cartItemCount = Math.Min(order.Entrees.Count,
                Math.Min(order.Sides.Count, order.Drinks.Count));
            }
            else
            {
                cartItemCount = order.Entrees.Count + order.Sides.Count + order.Drinks.Count;
            }
        }
        else
        {
            cartItemCount = 0;
        }
    }

    private void NavigateToCart()
    {
        NavigationManager.NavigateTo("/place-order");
    }

    private void NavigateToOrderHistory()
    {
        NavigationManager.NavigateTo("/order-history");
    }

    private void NavigateToUserProfile()
    {
        NavigationManager.NavigateTo("/profile");
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        CartNotification.OnCartChanged -= OnCartChanged;
    }
}