@if (IsVisible)
{
    <div class="toast-container position-fixed top-0 start-50 translate-middle-x mt-3" style="z-index: 9999;">
        <div class="confirmation-toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-icon-area">
                <i class="bi bi-check-circle-fill"></i>
            </div>
            <div class="toast-content">
                <strong class="toast-title">@Title</strong>
                <span class="toast-message">@Message</span>
            </div>
            <button type="button" class="toast-close" @onclick="Hide" aria-label="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    </div>
}

@code {
    [Parameter]
    public string Title { get; set; } = "Success";

    [Parameter]
    public string Message { get; set; } = "";

    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public EventCallback OnHidden { get; set; }

    [Parameter]
    public int DurationMs { get; set; } = 3000;

    private System.Threading.Timer? _timer;

    protected override void OnParametersSet()
    {
        if (IsVisible)
        {
            StartTimer();
        }
    }

    private void StartTimer()
    {
        _timer?.Dispose();
        _timer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
    {
            await Hide();
        });
        }, null, DurationMs, System.Threading.Timeout.Infinite);
    }

    private async Task Hide()
    {
        IsVisible = false;
        _timer?.Dispose();
        await OnHidden.InvokeAsync();
        StateHasChanged();
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}

<style>
    .confirmation-toast {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        min-width: 350px;
        max-width: 500px;
        padding: 1rem 1.25rem;
        background-color: #1e366c;
        color: #ffffff;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        animation: slideDown 0.3s ease-out;
    }

    .toast-icon-area {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: #8fbffa;
        flex-shrink: 0;
    }

    .toast-content {
        display: flex;
        flex-direction: column;
        flex: 1;
        min-width: 0;
    }

    .toast-title {
        font-size: 0.95rem;
        letter-spacing: -0.025em;
    }

    .toast-message {
        font-size: 0.85rem;
        color: #cbd5e1;
        margin-top: 0.15rem;
    }

    .toast-close {
        background: none;
        border: none;
        color: #94a3b8;
        cursor: pointer;
        padding: 0.25rem;
        font-size: 0.85rem;
        border-radius: 6px;
        transition: all 0.2s ease;
        flex-shrink: 0;
    }

    .toast-close:hover {
        color: #ffffff;
        background-color: rgba(255, 255, 255, 0.1);
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>