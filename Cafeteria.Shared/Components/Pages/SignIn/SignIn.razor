@page "/signin"
@layout EmptyLayout
@rendermode InteractiveServer

<PageTitle>Sign In - @PortalSettings.PortalName</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-sm-10 col-md-8 col-lg-6 col-xl-5">
            <div class="text-center mb-4">
                <h1 class="fw-bold mb-2 page-title">@PortalSettings.PortalName</h1>
                <p class="text-muted">@PortalSettings.SignInSubtitle</p>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    @if (HasError)
                    {
                        <div class="alert alert-danger d-flex align-items-center" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <div>@ErrorMessage</div>
                        </div>
                    }

                    <form @onsubmit="HandleSubmitAsync" @onsubmit:preventDefault="true">
                        <div class="mb-3">
                            <label for="username" class="form-label fw-medium">Username</label>
                            <input type="text" 
                                   class="form-control" 
                                   id="username" 
                                   @bind="Username" 
                                   placeholder="Enter your username"
                                   disabled="@IsLoading" 
                                   required />
                        </div>

                        <div class="mb-4">
                            <label for="password" class="form-label fw-medium">Password</label>
                            <input type="password" 
                                   class="form-control" 
                                   id="password" 
                                   @bind="Password"
                                   placeholder="Enter your password" 
                                   disabled="@IsLoading" 
                                   required />
                        </div>

                        <button type="submit" class="btn btn-signin w-100 py-2 fw-medium" disabled="@IsLoading">
                            @if (IsLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Signing in...</span>
                            }
                            else
                            {
                                <span>Sign In</span>
                            }
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
