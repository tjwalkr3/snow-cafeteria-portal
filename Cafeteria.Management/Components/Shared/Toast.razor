@if (IsVisible)
{
    <div class="toast-container position-fixed top-0 start-50 translate-middle-x mt-3" style="z-index: 9999;">
        <div class="mgmt-toast @GetToastModifier()" role="alert">
            <i class="bi @GetToastIcon() toast-icon"></i>
            <div class="toast-text">
                <strong>@GetToastTitle()</strong>
                <span>@Message</span>
            </div>
            <button type="button" class="toast-dismiss" @onclick="Close" aria-label="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    </div>
}

@code {
    [Parameter]
    public string Message { get; set; } = string.Empty;

    [Parameter]
    public ToastType Type { get; set; } = ToastType.Success;

    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    public enum ToastType
    {
        Success,
        Error,
        Warning,
        Info
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible)
        {
            await Task.Delay(3000);
            await Close();
        }
    }

    private string GetToastModifier()
    {
        return Type switch
        {
            ToastType.Success => "toast-success",
            ToastType.Error => "toast-error",
            ToastType.Warning => "toast-warning",
            ToastType.Info => "toast-info",
            _ => ""
        };
    }

    private string GetToastIcon()
    {
        return Type switch
        {
            ToastType.Success => "bi-check-circle-fill",
            ToastType.Error => "bi-exclamation-circle-fill",
            ToastType.Warning => "bi-exclamation-triangle-fill",
            ToastType.Info => "bi-info-circle-fill",
            _ => "bi-bell-fill"
        };
    }

    private string GetToastTitle()
    {
        return Type switch
        {
            ToastType.Success => "Success",
            ToastType.Error => "Error",
            ToastType.Warning => "Warning",
            ToastType.Info => "Info",
            _ => "Notification"
        };
    }

    private async Task Close()
    {
        IsVisible = false;
        await OnClose.InvokeAsync();
    }
}

<style>
    .mgmt-toast {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        min-width: 350px;
        max-width: 500px;
        padding: 1rem 1.25rem;
        background-color: #ffffff;
        color: #1f2937;
        border-radius: 10px;
        border-left: 4px solid #1b6ec2;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
        animation: toastSlideDown 0.3s ease-out;
    }

    .mgmt-toast.toast-success {
        border-left-color: #1b6ec2;
    }

    .mgmt-toast.toast-error {
        border-left-color: #dc3545;
    }

    .mgmt-toast.toast-warning {
        border-left-color: #e8a817;
    }

    .mgmt-toast.toast-info {
        border-left-color: #1b6ec2;
    }

    .toast-icon {
        font-size: 1.3rem;
        flex-shrink: 0;
    }

    .toast-success .toast-icon {
        color: #1b6ec2;
    }

    .toast-error .toast-icon {
        color: #dc3545;
    }

    .toast-warning .toast-icon {
        color: #e8a817;
    }

    .toast-info .toast-icon {
        color: #1b6ec2;
    }

    .toast-text {
        display: flex;
        flex-direction: column;
        flex: 1;
        min-width: 0;
        gap: 0.1rem;
    }

    .toast-text strong {
        font-size: 0.95rem;
    }

    .toast-text span {
        font-size: 0.85rem;
        color: #6b7280;
    }

    .toast-dismiss {
        background: none;
        border: none;
        color: #9ca3af;
        cursor: pointer;
        padding: 0.25rem;
        font-size: 0.8rem;
        border-radius: 6px;
        transition: all 0.2s ease;
        flex-shrink: 0;
    }

    .toast-dismiss:hover {
        color: #1f2937;
        background-color: rgba(0, 0, 0, 0.05);
    }

    @@keyframes toastSlideDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
