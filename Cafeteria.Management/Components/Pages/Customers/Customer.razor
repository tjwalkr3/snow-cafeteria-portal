@page "/customers"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@using Cafeteria.Management.Components.Shared
@using Cafeteria.Shared.DTOs.Swipe

<PageTitle>Customers</PageTitle>

<div class="px-3">
    <div class="d-flex justify-content-center align-items-center mb-4">
        <h1 class="page-title fw-bold mb-0">Customers</h1>
    </div>



    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Loading customers...</p>
        </div>
    }
    else if (allCustomers?.Any() ?? false)
    {
        <div class="row g-4 mb-4">
            @foreach (CustomerSwipeDto customer in allCustomers)
            {
                <div class="col-12 col-md-6 col-lg-4" @key="customer.BadgerId">
                    <div class="customer-card card h-100 border-1 rounded-3 shadow-sm">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3 pb-3 border-bottom">
                                <div class="flex-grow-1">
                                    <h5 class="customer-name fw-semibold mb-2">
                                        <i class="bi bi-person-circle me-2 text-primary"></i>@customer.CustName
                                    </h5>
                                    <p class="text-muted small mb-1">
                                        <i class="bi bi-envelope me-1"></i>@customer.Email
                                    </p>
                                </div>
                            </div>

                            <div class="d-flex flex-column gap-2">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="detail-label text-muted text-uppercase small fw-medium">Badger ID:</span>
                                    <span class="fw-semibold">@customer.BadgerId</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="detail-label text-muted text-uppercase small fw-medium">Swipe Balance:</span>
                                    <span class="swipe-balance fw-bold @GetSwipeBalanceClass(customer)">
                                        @GetSwipeBalanceDisplay(customer)
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state text-center p-5 bg-white rounded-3 shadow-sm">
            <i class="bi bi-people fs-1 mb-3 text-muted d-block"></i>
            <p class="fs-5 mb-2">@(allCustomers?.Count > 0 ? "No customers match your search." : "No customers found.")</p>
            <p class="text-muted small mb-0">@(allCustomers?.Count > 0 ? "Try adjusting your search criteria." : "Customers will appear here once registered.")</p>
        </div>
    }
</div>

<Toast Message="@toastMessage" Type="@toastType" IsVisible="@showToast" OnClose="@(() => showToast = false)" />
