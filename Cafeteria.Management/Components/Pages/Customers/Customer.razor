@page "/customers"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@using Cafeteria.Management.Components.Shared
@using Cafeteria.Shared.DTOs.Swipe

<PageTitle>Customers</PageTitle>

<div class="px-3">
    <div class="d-flex justify-content-center align-items-center">
        <h1 class="page-title fw-bold mb-0">Customers</h1>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12">
            <label class="form-label mb-0 me-2 text-nowrap fw-medium">Search:</label>
            <input type="text" class="form-control" placeholder="Search by name, email, or Badger ID..." @oninput="OnSearchChanged" value="@searchText" />
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Loading customers...</p>
        </div>
    }
    else if (FilteredCustomers.Any())
    {
        <div class="card border-1 rounded-3 shadow-sm mb-4">
            <div class="table-responsive">
                <table class="table table-hover customer-table mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Badger ID</th>
                            <th class="text-end">Swipe Balance</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (CustomerSwipeDto customer in FilteredCustomers)
                        {
                            <tr @key="customer.BadgerId" class="customer-row" @onclick="() => NavigateToCustomerOrders(customer.BadgerId)">
                                <td>
                                    <i class="bi bi-person-circle me-2 text-primary"></i>
                                    <span class="fw-semibold">@customer.CustName</span>
                                </td>
                                <td class="text-muted">@customer.Email</td>
                                <td class="text-muted">@customer.BadgerId</td>
                                <td class="text-end">
                                    <span class="swipe-badge fw-semibold @(customer.SwipeCount > 0 ? "swipe-positive" : "swipe-zero")">
                                        @customer.SwipeCount
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state text-center p-5 bg-white rounded-3 shadow-sm">
            <i class="bi bi-people fs-1 mb-3 text-muted d-block"></i>
            <p class="fs-5 mb-2">@(!string.IsNullOrWhiteSpace(searchText) ? "No customers match your search." : "No customers found.")</p>
            <p class="text-muted small mb-0">@(!string.IsNullOrWhiteSpace(searchText) ? "Try adjusting your search criteria." : "Customers will appear here once registered.")</p>
        </div>
    }
</div>

<Toast Message="@toastMessage" Type="@toastType" IsVisible="@showToast" OnClose="@(() => showToast = false)" />
