@page "/analytics"
@rendermode InteractiveServer

<PageTitle>Analytics</PageTitle>

<div class="px-3">
    <div class="d-flex justify-content-center align-items-center mb-4">
        <h1 class="page-title fw-bold mb-0">Analytics</h1>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Loading analytics...</p>
        </div>
    }
    else
    {
        <h6 class="section-label text-uppercase fw-semibold mb-3">Today</h6>
        <div class="row g-3 mb-5">
            <div class="col-12 col-sm-4">
                <div class="stat-card card border-0 shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3 p-4">
                        <div class="stat-icon bg-primary-subtle text-primary">
                            <i class="bi bi-receipt"></i>
                        </div>
                        <div>
                            <div class="stat-value">@ViewModel.TotalOrdersToday</div>
                            <div class="stat-label">Orders Placed</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-4">
                <div class="stat-card card border-0 shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3 p-4">
                        <div class="stat-icon bg-success-subtle text-success">
                            <i class="bi bi-currency-dollar"></i>
                        </div>
                        <div>
                            <div class="stat-value">$@ViewModel.RevenueToday.ToString("F2")</div>
                            <div class="stat-label">Card Revenue</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-4">
                <div class="stat-card card border-0 shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3 p-4">
                        <div class="stat-icon bg-warning-subtle text-warning">
                            <i class="bi bi-credit-card-2-front"></i>
                        </div>
                        <div>
                            <div class="stat-value">@ViewModel.SwipesToday</div>
                            <div class="stat-label">Swipes Used</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
