@page "/orders"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@using Cafeteria.Management.Components.Pages.Order

<PageTitle>Orders</PageTitle>

<div class="px-3">
    <div class="d-flex justify-content-center align-items-center">
        <h1 class="page-title fw-bold mb-0">Orders</h1>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-8">
            <label class="form-label mb-0 me-2 text-nowrap fw-medium">Search:</label>
            <div class="d-flex align-items-center">
                <input type="text" class="form-control" placeholder="Search by customer name, email, or order ID..." @oninput="OnSearchChanged" value="@searchText" />
            </div>
        </div>
        <div class="col-12 col-md-4">
            <label class="form-label mb-0 me-2 text-nowrap fw-medium">Payment Type:</label>
            <select class="form-select" @onchange="OnPaymentTypeChanged">
                <option value="">All</option>
                <option value="Card">Card</option>
                <option value="Swipe">Swipe</option>
            </select>
        </div>
    </div>

    @if (FilteredOrders.Any())
    {
        <div class="row g-4 mb-4">
            @foreach (var order in FilteredOrders)
            {
                <div class="col-12 col-md-6 col-lg-4" @key="order.Id">
                    <div class="order-card card h-100 border-1 rounded-3 shadow-sm">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3 pb-3 border-bottom">
                                <div class="flex-grow-1">
                                    <a href="orders/@order.Id" class="text-decoration-none text-dark">
                                        <h5 class="fw-semibold mb-1 order-link">Order #@order.Id</h5>
                                    </a>
                                    <p class="text-muted small mb-0">@order.OrderTime.ToString("MMM dd, yyyy h:mm tt")</p>
                                </div>
                                <span class="badge @(order.PaymentType == "Card" ? "bg-primary" : "bg-success")">
                                    @order.PaymentType
                                </span>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="text-muted small text-uppercase fw-medium">Customer:</span>
                                    @if (order.CustomerBadgerId.HasValue)
                                    {
                                        <a href="orders/customer/@order.CustomerBadgerId" class="fw-medium text-decoration-none customer-link">
                                            @(order.CustomerName ?? "Guest")
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="fw-medium">@(order.CustomerName ?? "Guest")</span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(order.CustomerEmail))
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="text-muted small text-uppercase fw-medium">Email:</span>
                                        <span class="text-truncate" style="max-width: 150px;" title="@order.CustomerEmail">@order.CustomerEmail</span>
                                    </div>
                                }
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="text-muted small text-uppercase fw-medium">Items:</span>
                                    <span>@order.ItemCount</span>
                                </div>
                            </div>

                            <div class="pt-3 border-top">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-muted small text-uppercase fw-medium">Total:</span>
                                    @if (order.TotalPrice.HasValue)
                                    {
                                        <span class="fs-5 fw-bold">$@((order.TotalPrice.Value + order.Tax).ToString("F2"))</span>
                                    }
                                    else if (order.TotalSwipe.HasValue)
                                    {
                                        <span class="fs-5 fw-bold">@order.TotalSwipe.Value Swipe(s)</span>
                                    }
                                    else
                                    {
                                        <span class="fs-5 fw-bold text-muted">N/A</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state text-center p-5 bg-white rounded-3 shadow-sm">
            <i class="bi bi-receipt fs-1 mb-3 text-muted d-block"></i>
            <p class="fs-5 mb-2">No orders found.</p>
            <p class="text-muted small mb-0">Orders will appear here once customers start placing them.</p>
        </div>
    }
</div>

