@page "/orders"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@using Cafeteria.Management.Components.Pages.Order

<PageTitle>Orders</PageTitle>

<div class="px-3">
    <div class="d-flex justify-content-center align-items-center">
        <h1 class="page-title fw-bold mb-0">All Orders</h1>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-8">
            <label class="form-label mb-0 me-2 text-nowrap fw-medium">Search:</label>
            <input type="text" class="form-control" placeholder="Search by customer name, email, or order ID..."
                   @oninput="OnSearchChanged" value="@searchText" />
        </div>
        <div class="col-12 col-md-4">
            <label class="form-label mb-0 me-2 text-nowrap fw-medium">Payment Type:</label>
            <select class="form-select" @onchange="OnPaymentTypeChanged">
                <option value="">All</option>
                <option value="Card">Card</option>
                <option value="Swipe">Swipe</option>
            </select>
        </div>
    </div>

    @if (FilteredOrders.Any())
    {
        <div class="card border-1 rounded-3 shadow-sm mb-4">
            <div class="table-responsive">
                <table class="table table-hover orders-table mb-0">
                    <thead>
                        <tr>
                            <th>Order #</th>
                            <th>Date & Time</th>
                            <th>Customer</th>
                            <th>Email</th>
                            <th>Payment</th>
                            <th class="text-center">Items</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in FilteredOrders)
                        {
                            <tr @key="order.Id" class="order-row" @onclick="() => NavigateToOrder(order.Id)">
                                <td class="fw-semibold">#@order.Id</td>
                                <td class="text-muted text-nowrap">@order.OrderTime.ToString("MMM dd, yyyy h:mm tt")</td>
                                <td>
                                    @if (order.CustomerBadgerId.HasValue)
                                    {
                                        <a href="orders/customer/@order.CustomerBadgerId"
                                           class="customer-link fw-medium text-decoration-none"
                                           @onclick:stopPropagation="true">
                                            <i class="bi bi-person-circle me-1"></i>@(order.CustomerName ?? "Guest")
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted"><i class="bi bi-person me-1"></i>@(order.CustomerName ?? "Guest")</span>
                                    }
                                </td>
                                <td class="text-muted">
                                    <span class="text-truncate d-inline-block" style="max-width: 180px;" title="@order.CustomerEmail">
                                        @(order.CustomerEmail ?? "—")
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @(order.PaymentType == "Card" ? "bg-primary" : "bg-success")">
                                        @order.PaymentType
                                    </span>
                                </td>
                                <td class="text-center">@order.ItemCount</td>
                                <td class="text-end fw-semibold">
                                    @if (order.TotalPrice.HasValue)
                                    {
                                        <span>$@((order.TotalPrice.Value + order.Tax).ToString("F2"))</span>
                                    }
                                    else if (order.TotalSwipe.HasValue)
                                    {
                                        <span>@order.TotalSwipe.Value swipe(s)</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state text-center p-5 bg-white rounded-3 shadow-sm">
            <i class="bi bi-receipt fs-1 mb-3 text-muted d-block"></i>
            <p class="fs-5 mb-2">No orders found.</p>
            <p class="text-muted small mb-0">Orders will appear here once customers start placing them.</p>
        </div>
    }
</div>
