@page "/orders/{OrderId:int}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@using Cafeteria.Management.Components.Pages.Order

<PageTitle>Order Details</PageTitle>

<div class="px-3">
    <div class="mb-4">
        <a href="orders" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to All Orders
        </a>
    </div>

    @if (Order != null)
    {
        @* Header *@
        <div class="d-flex justify-content-between align-items-start mb-4">
            <div>
                <h1 class="order-title fw-bold mb-1">Order #@Order.Id</h1>
                <p class="text-muted mb-0">
                    <i class="bi bi-calendar3 me-1"></i>@Order.OrderTime.ToString("MMMM dd, yyyy 'at' h:mm tt")
                </p>
            </div>
            <span class="badge fs-6 px-3 py-2 @(Order.PaymentType == "Card" ? "bg-primary" : "bg-success")">
                @Order.PaymentType
            </span>
        </div>

        @* Customer + Summary row *@
        <div class="row g-4 mb-4">
            <div class="col-12 col-md-6">
                <div class="section-card card h-100 border-1 rounded-3 shadow-sm">
                    <div class="section-header card-header">
                        <i class="bi bi-person me-2"></i>Customer
                    </div>
                    <div class="card-body p-4">
                        <div class="detail-row">
                            <span class="detail-label">Name</span>
                            @if (Order.CustomerBadgerId.HasValue)
                            {
                                <a href="orders/customer/@Order.CustomerBadgerId" class="fw-semibold customer-link text-decoration-none">
                                    @(Order.CustomerName ?? "Guest")
                                    <i class="bi bi-box-arrow-up-right ms-1 small"></i>
                                </a>
                            }
                            else
                            {
                                <span class="fw-semibold">@(Order.CustomerName ?? "Guest")</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(Order.CustomerEmail))
                        {
                            <div class="detail-row">
                                <span class="detail-label">Email</span>
                                <span>@Order.CustomerEmail</span>
                            </div>
                        }
                        @if (Order.CustomerBadgerId.HasValue)
                        {
                            <div class="detail-row">
                                <span class="detail-label">Badger ID</span>
                                <span class="fw-semibold">@Order.CustomerBadgerId</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6">
                <div class="section-card card h-100 border-1 rounded-3 shadow-sm">
                    <div class="section-header card-header">
                        <i class="bi bi-receipt me-2"></i>Summary
                    </div>
                    <div class="card-body p-4">
                        <div class="detail-row">
                            <span class="detail-label">Items</span>
                            <span class="fw-semibold">@Order.ItemCount</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Payment</span>
                            <span class="fw-semibold">@Order.PaymentType</span>
                        </div>
                        @if (Order.TotalPrice.HasValue)
                        {
                            <div class="detail-row">
                                <span class="detail-label">Subtotal</span>
                                <span>$@Order.TotalPrice.Value.ToString("F2")</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Tax</span>
                                <span>$@Order.Tax.ToString("F2")</span>
                            </div>
                            <hr class="my-2" />
                            <div class="detail-row">
                                <span class="detail-label fw-bold">Total</span>
                                <span class="fs-5 fw-bold total-amount">$@((Order.TotalPrice.Value + Order.Tax).ToString("F2"))</span>
                            </div>
                        }
                        else if (Order.TotalSwipe.HasValue)
                        {
                            <hr class="my-2" />
                            <div class="detail-row">
                                <span class="detail-label fw-bold">Total</span>
                                <span class="fs-5 fw-bold total-amount">@Order.TotalSwipe.Value Swipe(s)</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Items *@
        @if (Order.FoodItems.Any())
        {
            <div class="section-card card border-1 rounded-3 shadow-sm mb-4">
                <div class="section-header card-header">
                    <i class="bi bi-bag me-2"></i>Items Ordered
                </div>
                @if (Order.PaymentType == "Swipe")
                {
                    <div class="card-body p-4">
                        @for (int i = 0; i + 2 < Order.FoodItems.Count; i += 3)
                        {
                            var entree = Order.FoodItems[i];
                            var side = Order.FoodItems[i + 1];
                            var drink = Order.FoodItems[i + 2];
                            var swipeNum = i / 3 + 1;
                            <div class="swipe-group @(i + 3 < Order.FoodItems.Count ? "mb-4 pb-4 border-bottom" : "")">
                                @if (Order.FoodItems.Count > 3)
                                {
                                    <p class="swipe-label mb-2">Swipe @swipeNum</p>
                                }
                                <div class="detail-row">
                                    <span class="detail-label">Entree</span>
                                    <div class="text-end">
                                        <span class="fw-medium">@entree.Name</span>
                                        @if (entree.Options.Any())
                                        {
                                            <ul class="mb-0 mt-1 small text-muted list-unstyled">
                                                @foreach (var opt in entree.Options)
                                                {
                                                    <li>@opt.FoodOptionName</li>
                                                }
                                            </ul>
                                        }
                                    </div>
                                </div>
                                <div class="detail-row">
                                    <span class="detail-label">Side</span>
                                    <div class="text-end">
                                        <span class="fw-medium">@side.Name</span>
                                        @if (side.Options.Any())
                                        {
                                            <ul class="mb-0 mt-1 small text-muted list-unstyled">
                                                @foreach (var opt in side.Options)
                                                {
                                                    <li>@opt.FoodOptionName</li>
                                                }
                                            </ul>
                                        }
                                    </div>
                                </div>
                                <div class="detail-row">
                                    <span class="detail-label">Drink</span>
                                    <span class="fw-medium">@drink.Name</span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table items-table mb-0">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th class="text-end">Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Order.FoodItems)
                                {
                                    <tr @key="item.Name">
                                        <td>
                                            <span class="fw-medium">@item.Name</span>
                                            @if (item.Options.Any())
                                            {
                                                <ul class="mb-0 mt-1 ps-3 small text-muted">
                                                    @foreach (var opt in item.Options)
                                                    {
                                                        <li>@opt.FoodOptionName</li>
                                                    }
                                                </ul>
                                            }
                                        </td>
                                        <td class="text-end text-muted">
                                            @if (item.CardCost.HasValue)
                                            {
                                                <span>$@item.CardCost.Value.ToString("F2")</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    }
    else
    {
        <div class="empty-state text-center p-5 bg-white rounded-3 shadow-sm">
            <i class="bi bi-exclamation-circle fs-1 mb-3 text-muted d-block"></i>
            <p class="fs-5 mb-2">Order not found.</p>
            <p class="text-muted small mb-0">The order you're looking for doesn't exist or has been removed.</p>
        </div>
    }
</div>
