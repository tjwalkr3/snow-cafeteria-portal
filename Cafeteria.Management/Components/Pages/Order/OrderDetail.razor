@page "/orders/{OrderId:int}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@using Cafeteria.Management.Components.Pages.Order

<PageTitle>Order Details</PageTitle>

<div class="px-3">
    <div class="mb-4">
        <a href="orders" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to All Orders
        </a>
    </div>

    @if (Order != null)
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <h1 class="fw-bold mb-1">Order #@Order.Id</h1>
                        <p class="text-muted mb-0">@Order.OrderTime.ToString("MMMM dd, yyyy 'at' h:mm tt")</p>
                    </div>
                    <span class="badge fs-6 @(Order.PaymentType == "Card" ? "bg-primary" : "bg-success")">
                        @Order.PaymentType
                    </span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <h5 class="fw-semibold mb-3 text-muted text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.05em;">Customer Information</h5>
                        <div class="bg-light rounded-3 p-3">
                            @if (Order.CustomerBadgerId.HasValue)
                            {
                                <div class="mb-2">
                                    <span class="text-muted small">Name:</span>
                                    <a href="orders/customer/@Order.CustomerBadgerId" class="ms-2 fw-medium text-decoration-none customer-link">
                                        @(Order.CustomerName ?? "Guest")
                                        <i class="bi bi-box-arrow-up-right ms-1 small"></i>
                                    </a>
                                </div>
                            }
                            else
                            {
                                <div class="mb-2">
                                    <span class="text-muted small">Name:</span>
                                    <span class="ms-2 fw-medium">@(Order.CustomerName ?? "Guest")</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(Order.CustomerEmail))
                            {
                                <div class="mb-2">
                                    <span class="text-muted small">Email:</span>
                                    <span class="ms-2">@Order.CustomerEmail</span>
                                </div>
                            }
                            @if (Order.CustomerBadgerId.HasValue)
                            {
                                <div>
                                    <span class="text-muted small">Badger ID:</span>
                                    <span class="ms-2">@Order.CustomerBadgerId</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <h5 class="fw-semibold mb-3 text-muted text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.05em;">Order Summary</h5>
                        <div class="bg-light rounded-3 p-3">
                            <div class="mb-2">
                                <span class="text-muted small">Items:</span>
                                <span class="ms-2 fw-medium">@Order.ItemCount</span>
                            </div>
                            <div class="mb-2">
                                <span class="text-muted small">Payment Method:</span>
                                <span class="ms-2 fw-medium">@Order.PaymentType</span>
                            </div>
                            @if (Order.TotalPrice.HasValue)
                            {
                                <div class="mb-2">
                                    <span class="text-muted small">Subtotal:</span>
                                    <span class="ms-2">$@Order.TotalPrice.Value.ToString("F2")</span>
                                </div>
                                <div class="mb-2">
                                    <span class="text-muted small">Tax:</span>
                                    <span class="ms-2">$@Order.Tax.ToString("F2")</span>
                                </div>
                                <hr class="my-2" />
                                <div>
                                    <span class="text-muted small">Total:</span>
                                    <span class="ms-2 fs-5 fw-bold">$@((Order.TotalPrice.Value + Order.Tax).ToString("F2"))</span>
                                </div>
                            }
                            else if (Order.TotalSwipe.HasValue)
                            {
                                <div>
                                    <span class="text-muted small">Total:</span>
                                    <span class="ms-2 fs-5 fw-bold">@Order.TotalSwipe.Value Swipe(s)</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @if (Order.FoodItems.Any())
                {
                    <div class="mt-2">
                        <h5 class="fw-semibold mb-3 text-muted text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.05em;">Items Ordered</h5>
                        <div class="bg-light rounded-3 p-3">
                            @if (Order.PaymentType == "Swipe")
                            {
                                @for (int i = 0; i + 2 < Order.FoodItems.Count; i += 3)
                                {
                                    var entree = Order.FoodItems[i];
                                    var side = Order.FoodItems[i + 1];
                                    var drink = Order.FoodItems[i + 2];
                                    var swipeNum = i / 3 + 1;
                                    <div class="mb-3 @(i + 3 < Order.FoodItems.Count ? "pb-3 border-bottom" : "")">
                                        @if (Order.FoodItems.Count > 3)
                                        {
                                            <div class="fw-semibold small text-muted mb-2">Swipe @swipeNum</div>
                                        }
                                        <div class="mb-1">
                                            <span class="text-muted small">Entree:</span>
                                            <span class="ms-2 fw-medium">@entree.Name</span>
                                            @if (entree.Options.Any())
                                            {
                                                <ul class="mb-0 mt-1 ps-4 small text-muted">
                                                    @foreach (var opt in entree.Options)
                                                    {
                                                        <li>@opt.FoodOptionName</li>
                                                    }
                                                </ul>
                                            }
                                        </div>
                                        <div class="mb-1">
                                            <span class="text-muted small">Side:</span>
                                            <span class="ms-2 fw-medium">@side.Name</span>
                                            @if (side.Options.Any())
                                            {
                                                <ul class="mb-0 mt-1 ps-4 small text-muted">
                                                    @foreach (var opt in side.Options)
                                                    {
                                                        <li>@opt.FoodOptionName</li>
                                                    }
                                                </ul>
                                            }
                                        </div>
                                        <div>
                                            <span class="text-muted small">Drink:</span>
                                            <span class="ms-2 fw-medium">@drink.Name</span>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                @foreach (var item in Order.FoodItems)
                                {
                                    <div class="mb-2">
                                        <div class="d-flex justify-content-between">
                                            <span class="fw-medium">@item.Name</span>
                                            @if (item.CardCost.HasValue)
                                            {
                                                <span class="text-muted small">$@item.CardCost.Value.ToString("F2")</span>
                                            }
                                        </div>
                                        @if (item.Options.Any())
                                        {
                                            <ul class="mb-0 mt-1 ps-4 small text-muted">
                                                @foreach (var opt in item.Options)
                                                {
                                                    <li>@opt.FoodOptionName</li>
                                                }
                                            </ul>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }

                @if (Order.CustomerBadgerId.HasValue)
                {
                    <div class="mt-3">
                        <a href="orders/customer/@Order.CustomerBadgerId" class="btn btn-outline-primary">
                            <i class="bi bi-clock-history me-2"></i>View Customer's Order History
                        </a>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="empty-state text-center p-5 bg-white rounded-3 shadow-sm">
            <i class="bi bi-exclamation-circle fs-1 mb-3 text-muted d-block"></i>
            <p class="fs-5 mb-2">Order not found.</p>
            <p class="text-muted small mb-0">The order you're looking for doesn't exist or has been removed.</p>
        </div>
    }
</div>

<style>
    .customer-link {
        color: var(--bs-primary);
    }
    .customer-link:hover {
        text-decoration: underline !important;
    }
</style>
