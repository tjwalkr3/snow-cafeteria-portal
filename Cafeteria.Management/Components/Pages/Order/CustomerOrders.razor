@page "/orders/customer/{BadgerId:int}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@using Cafeteria.Management.Components.Pages.Order

<PageTitle>Customer Orders</PageTitle>

<div class="px-3">
    <div class="mb-4">
        <a href="orders" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to All Orders
        </a>
    </div>

    <div class="d-flex justify-content-center align-items-center mb-2">
        <h1 class="page-title fw-bold mb-0">Customer Order History</h1>
    </div>

    @if (Orders.Any())
    {
        <div class="text-center mb-4">
            <h4 class="text-muted">@Orders.First().CustomerName</h4>
            <p class="text-muted small mb-0">@Orders.First().CustomerEmail</p>
            <p class="text-muted small">@Orders.Count order(s)</p>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-md-8">
                <label class="form-label mb-0 me-2 text-nowrap fw-medium">Search:</label>
                <div class="d-flex align-items-center">
                    <input type="text" class="form-control" placeholder="Search by order ID..." @oninput="OnSearchChanged" value="@searchText" />
                </div>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label mb-0 me-2 text-nowrap fw-medium">Payment Type:</label>
                <select class="form-select" @onchange="OnPaymentTypeChanged">
                    <option value="">All</option>
                    <option value="Card">Card</option>
                    <option value="Swipe">Swipe</option>
                </select>
            </div>
        </div>

        <div class="row g-4 mb-4">
            @foreach (var order in FilteredOrders)
            {
                <div class="col-12 col-md-6 col-lg-4" @key="order.Id">
                    <div class="card h-100 border-1 rounded-3 shadow-sm">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3 pb-3 border-bottom">
                                <div class="flex-grow-1">
                                    <a href="orders/@order.Id" class="text-decoration-none text-dark">
                                        <h5 class="fw-semibold mb-1 order-link">Order #@order.Id</h5>
                                    </a>
                                    <p class="text-muted small mb-0">@order.OrderTime.ToString("MMM dd, yyyy h:mm tt")</p>
                                </div>
                                <span class="badge @(order.PaymentType == "Card" ? "bg-primary" : "bg-success")">
                                    @order.PaymentType
                                </span>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="text-muted small text-uppercase fw-medium">Items:</span>
                                    <span>@order.ItemCount</span>
                                </div>
                            </div>

                            <div class="pt-3 border-top">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-muted small text-uppercase fw-medium">Total:</span>
                                    @if (order.TotalPrice.HasValue)
                                    {
                                        <span class="fs-5 fw-bold">$@((order.TotalPrice.Value + order.Tax).ToString("F2"))</span>
                                    }
                                    else if (order.TotalSwipe.HasValue)
                                    {
                                        <span class="fs-5 fw-bold">@order.TotalSwipe.Value Swipe(s)</span>
                                    }
                                    else
                                    {
                                        <span class="fs-5 fw-bold text-muted">N/A</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state text-center p-5 bg-white rounded-3 shadow-sm">
            <i class="bi bi-receipt fs-1 mb-3 text-muted d-block"></i>
            <p class="fs-5 mb-2">No orders found for this customer.</p>
            <p class="text-muted small mb-0">This customer hasn't placed any orders yet.</p>
        </div>
    }
</div>

<style>
    .order-link:hover {
        color: var(--bs-primary) !important;
    }
</style>
