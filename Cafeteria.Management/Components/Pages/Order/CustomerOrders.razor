@page "/orders/customer/{BadgerId:int}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@using Cafeteria.Management.Components.Pages.Order

<PageTitle>Customer Order History</PageTitle>

<div class="px-3">
    <div class="mb-4">
        <a href="orders" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to All Orders
        </a>
    </div>

    @if (Orders.Any())
    {
        <div class="customer-summary card border-1 rounded-3 shadow-sm mb-4">
            <div class="card-body p-4 d-flex align-items-center gap-3">
                <i class="bi bi-person-circle fs-1 text-primary flex-shrink-0"></i>
                <div class="flex-grow-1">
                    <h4 class="fw-bold mb-0">@Orders.First().CustomerName</h4>
                    <p class="text-muted small mb-0"><i class="bi bi-envelope me-1"></i>@Orders.First().CustomerEmail</p>
                </div>
                <span class="badge bg-primary rounded-pill px-3 py-2 fs-6">@Orders.Count order(s)</span>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-md-8">
                <label class="form-label mb-0 me-2 text-nowrap fw-medium">Search:</label>
                <input type="text" class="form-control" placeholder="Search by order ID..." @oninput="OnSearchChanged" value="@searchText" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label mb-0 me-2 text-nowrap fw-medium">Payment Type:</label>
                <select class="form-select" @onchange="OnPaymentTypeChanged">
                    <option value="">All</option>
                    <option value="Card">Card</option>
                    <option value="Swipe">Swipe</option>
                </select>
            </div>
        </div>

        <div class="card border-1 rounded-3 shadow-sm mb-4">
            <div class="table-responsive">
                <table class="table table-hover order-table mb-0">
                    <thead>
                        <tr>
                            <th>Order</th>
                            <th>Date</th>
                            <th>Payment</th>
                            <th class="text-center">Items</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in FilteredOrders)
                        {
                            <tr @key="order.Id" class="order-row" @onclick="() => NavigateToOrder(order.Id)">
                                <td><span class="fw-semibold">#@order.Id</span></td>
                                <td class="text-muted">@order.OrderTime.ToString("MMM dd, yyyy h:mm tt")</td>
                                <td>
                                    <span class="badge @(order.PaymentType == "Card" ? "bg-primary" : "bg-success")">
                                        @order.PaymentType
                                    </span>
                                </td>
                                <td class="text-center">@order.ItemCount</td>
                                <td class="text-end fw-bold">
                                    @if (order.TotalPrice.HasValue)
                                    {
                                        <span>$@((order.TotalPrice.Value + order.Tax).ToString("F2"))</span>
                                    }
                                    else if (order.TotalSwipe.HasValue)
                                    {
                                        <span>@order.TotalSwipe.Value Swipe(s)</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state text-center p-5 bg-white rounded-3 shadow-sm">
            <i class="bi bi-receipt fs-1 mb-3 text-muted d-block"></i>
            <p class="fs-5 mb-2">No orders found for this customer.</p>
            <p class="text-muted small mb-0">This customer hasn't placed any orders yet.</p>
        </div>
    }
</div>
