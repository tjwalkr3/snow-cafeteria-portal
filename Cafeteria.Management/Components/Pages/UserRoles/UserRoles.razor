@page "/user-roles"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@using Cafeteria.Management.Components.Shared
@using Cafeteria.Shared.DTOs.Customer

<PageTitle>User Roles</PageTitle>

@if (!_isAdmin)
{
    <section class="access-denied-wrap">
        <div class="access-denied-card">
            <h1>Access Restricted</h1>
            <p>You do not have permission to manage user roles.</p>
        </div>
    </section>
}
else
{
<div class="@(hasSearch ? "ur-results-layout" : "ur-idle-layout")">

    <div class="ur-header">
        <i class="bi bi-person-badge-fill ur-idle-icon"></i>
        <h1 class="page-title fw-bold">User Roles</h1>
        <p class="ur-idle-hint">Search for a user by name or email to view and manage their role.</p>
    </div>

    <div class="ur-search-wrap">
        <span class="ur-search-icon bi bi-search"></span>
        <input class="ur-search-input"
               type="text"
               placeholder="Search by name or email..."
               @oninput="OnSearchInput"
               value="@searchText"
               autofocus />
    </div>

    <div class="ur-results">
        @if (isLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-3 text-muted">Loading users...</p>
            </div>
        }
        else if (hasSearch && customers.Any())
        {
            <div class="card border-1 rounded-3 shadow-sm mb-4">
                <div class="table-responsive">
                    <table class="table table-hover ur-table mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Badger ID</th>
                                <th>Current Role</th>
                                <th class="text-center">Food Service</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var customer in customers)
                            {
                                <tr @key="customer.Email">
                                    <td>
                                        <i class="bi bi-person-circle me-2 text-primary"></i>
                                        <span class="fw-semibold">@customer.CustName</span>
                                    </td>
                                    <td class="text-muted">@customer.Email</td>
                                    <td class="text-muted">@customer.BadgerId</td>
                                    <td>
                                        @if (string.Equals(customer.UserRole, "admin", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge bg-danger">Admin</span>
                                        }
                                        else if (string.Equals(customer.UserRole, "food-service", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge bg-warning text-dark">Food Service</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Customer</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (!string.Equals(customer.UserRole, "admin", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <div class="form-check form-switch d-inline-block">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       role="switch"
                                                       checked="@string.Equals(customer.UserRole, "food-service", StringComparison.OrdinalIgnoreCase)"
                                                       disabled="@togglingEmail.Contains(customer.Email)"
                                                       @onchange="() => ToggleRole(customer)" />
                                            </div>
                                            @if (togglingEmail.Contains(customer.Email))
                                            {
                                                <span class="spinner-border spinner-border-sm ms-1" role="status"></span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted small">N/A</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else if (hasSearch)
        {
            <div class="text-center p-5 bg-white rounded-3 shadow-sm">
                <i class="bi bi-person-slash fs-1 mb-3 text-muted d-block"></i>
                <p class="fs-5 mb-1">No users match your search.</p>
                <p class="text-muted small mb-0">Try a different name or email.</p>
            </div>
        }
    </div>
</div>

<Toast Message="@toastMessage" Type="@toastType" IsVisible="@showToast" OnClose="@(() => showToast = false)" />
}
