@page "/location-station"
@using Cafeteria.Shared.Enums
@rendermode InteractiveServer

<h1>Locations & Stations</h1>
<p>Manage business hours for locations and their stations.</p>

@if (Locations.Any())
{
    <ul class="nav nav-tabs">
        @foreach (var location in Locations)
        {
            <li class="nav-item">
                <button class="nav-link @(SelectedLocationId == location.Id ? "active" : "")"
                        @onclick="() => SelectLocation(location.Id)">
                    @location.LocationName
                </button>
            </li>
        }
    </ul>

    <div class="tab-content-area">
        @if (SelectedLocation is not null)
        {
            <p class="text-muted mb-3">@SelectedLocation.LocationDescription</p>

            <ul class="nav nav-tabs mb-3">
                <li class="nav-item">
                    <button class="nav-link @(ActiveTab == "hours" ? "active" : "")"
                            @onclick='@(() => SetActiveTab("hours"))'>
                        <i class="bi bi-clock me-1"></i>Hours
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(ActiveTab == "exceptions" ? "active" : "")"
                            @onclick='@(() => SetActiveTab("exceptions"))'>
                        <i class="bi bi-exclamation-circle me-1"></i>Exceptions
                    </button>
                </li>
            </ul>

            @if (ActiveTab == "hours")
            {
                <h5><i class="bi bi-clock me-2"></i>Location Hours</h5>
                <BusinessHoursEditor @key="@($"loc-{SelectedLocation.Id}")"
                                     EntityId="@SelectedLocation.Id"
                                     IsStation="false" />

                @if (Stations.Any())
                {
                    <hr />
                    <h5><i class="bi bi-shop me-2"></i>Station Hours</h5>

                    <div class="row">
                        @foreach (var station in Stations)
                        {
                            <div class="col-lg-6 mb-3">
                                <div class="card h-100 station-card">
                                    <div class="card-header station-card-header">
                                        <h6 class="mb-0">@station.StationName</h6>
                                    </div>
                                    <div class="card-body">
                                        <small class="text-muted d-block mb-2">@station.StationDescription</small>
                                        <BusinessHoursEditor @key="@($"sta-{station.Id}")"
                                                             EntityId="@station.Id"
                                                             IsStation="true" />
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mt-3">No stations found for this location.</p>
                }
            }
            else if (ActiveTab == "exceptions")
            {
                <h5><i class="bi bi-exclamation-circle me-2"></i>Location Exceptions</h5>
                <SchedulingExceptionsEditor @key="@($"loc-exc-{SelectedLocation.Id}")"
                                            EntityId="@SelectedLocation.Id"
                                            IsStation="false" />

                @if (Stations.Any())
                {
                    <hr />
                    <h5><i class="bi bi-exclamation-circle me-2"></i>Station Exceptions</h5>

                    <div class="row">
                        @foreach (var station in Stations)
                        {
                            <div class="col-lg-6 mb-3">
                                <div class="card h-100 station-card">
                                    <div class="card-header station-card-header">
                                        <h6 class="mb-0">@station.StationName</h6>
                                    </div>
                                    <div class="card-body">
                                        <small class="text-muted d-block mb-2">@station.StationDescription</small>
                                        <SchedulingExceptionsEditor @key="@($"sta-exc-{station.Id}")"
                                                                    EntityId="@station.Id"
                                                                    IsStation="true" />
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mt-3">No stations found for this location.</p>
                }
            }
        }
    </div>
}
