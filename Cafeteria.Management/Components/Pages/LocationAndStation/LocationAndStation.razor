@page "/business-hours"
@using Cafeteria.Shared.Enums
@rendermode InteractiveServer

<PageTitle>Business Hours</PageTitle>

<div class="px-3">
    <div class="d-flex justify-content-center align-items-center mb-4">
        <h1 class="page-title fw-bold mb-0">Business Hours</h1>
    </div>

@if (Locations.Any())
{
    <ul class="nav nav-tabs">
        @foreach (var location in Locations)
        {
            <li class="nav-item">
                <button class="nav-link @(SelectedLocationId == location.Id ? "active" : "")"
                        @onclick="() => SelectLocation(location.Id)">
                    @location.LocationName
                </button>
            </li>
        }
    </ul>

    <div class="tab-content-area">
        @if (SelectedLocation is not null)
        {
            <p class="text-muted mb-3">@SelectedLocation.LocationDescription</p>

            <ul class="nav nav-tabs mb-3">
                <li class="nav-item">
                    <button class="nav-link @(ActiveTab == "hours" ? "active" : "")"
                            @onclick='@(() => SetActiveTab("hours"))'>
                        <i class="bi bi-clock me-1"></i>Hours
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(ActiveTab == "exceptions" ? "active" : "")"
                            @onclick='@(() => SetActiveTab("exceptions"))'>
                        <i class="bi bi-exclamation-circle me-1"></i>Exceptions
                    </button>
                </li>
            </ul>

            @if (ActiveTab == "hours")
            {
                <h5><i class="bi bi-clock me-2"></i>Location Hours</h5>
                <BusinessHoursEditor @key="@($"loc-{SelectedLocation.Id}")"
                                     EntityId="@SelectedLocation.Id"
                                     IsStation="false" />

                @if (Stations.Any())
                {
                    <hr />
                    <h5><i class="bi bi-shop me-2"></i>Station Hours</h5>

                    <div class="row">
                        @foreach (var station in Stations)
                        {
                            <div class="col-lg-6 mb-3">
                                <div class="card h-100 station-card">
                                    <div class="card-header station-card-header">
                                        <h6 class="mb-0">@station.StationName</h6>
                                    </div>
                                    <div class="card-body">
                                        <small class="text-muted d-block mb-2">@station.StationDescription</small>
                                        <BusinessHoursEditor @key="@($"sta-{station.Id}")"
                                                             EntityId="@station.Id"
                                                             IsStation="true" />
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mt-3">No stations found for this location.</p>
                }
            }
            else if (ActiveTab == "exceptions")
            {
                <h5><i class="bi bi-exclamation-circle me-2"></i>Location Exceptions</h5>
                <SchedulingExceptionsEditor @ref="LocationExceptionsEditor"
                                            @key="@($"loc-exc-{SelectedLocation.Id}")"
                                            EntityId="@SelectedLocation.Id"
                                            IsStation="false"
                                            OnModalStateChanged="@OnExceptionsModalStateChanged" />

                @if (Stations.Any())
                {
                    <hr />
                    <h5><i class="bi bi-exclamation-circle me-2"></i>Station Exceptions</h5>

                    <div class="row">
                        @foreach (var station in Stations)
                        {
                            <div class="col-lg-6 mb-3">
                                <div class="card h-100 station-card">
                                    <div class="card-header station-card-header">
                                        <h6 class="mb-0">@station.StationName</h6>
                                    </div>
                                    <div class="card-body">
                                        <small class="text-muted d-block mb-2">@station.StationDescription</small>
                                        <SchedulingExceptionsEditor @ref="StationExceptionsEditorRefs[station.Id]"
                                                                    @key="@($"sta-exc-{station.Id}")"
                                                                    EntityId="@station.Id"
                                                                    IsStation="true"
                                                                    OnModalStateChanged="@OnExceptionsModalStateChanged" />
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mt-3">No stations found for this location.</p>
                }
            }
        }
    </div>
}

<!-- Page-level modal for exceptions -->
@{
    SchedulingExceptionsEditor? activeEditor = GetActiveExceptionsEditor();
    if (activeEditor?.ShowModal == true)
    {
        <div class="modal-backdrop fade show"></div>
        <div class="modal fade show d-block" tabindex="-1" role="dialog" style="position: fixed; top: 0; left: 0; z-index: 9999; width: 100%; height: 100%;">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bi @(activeEditor.IsEditing ? "bi-pencil" : "bi-plus-circle") me-2"></i>@(activeEditor.IsEditing ? "Edit" : "Add") Exception</h5>
                        <button type="button" class="btn-close" @onclick="@(() => activeEditor.CloseModal())" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Start Date/Time</label>
                            <input type="datetime-local" class="form-control" @bind="activeEditor.EditStartDateTime" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">End Date/Time</label>
                            <input type="datetime-local" class="form-control" @bind="activeEditor.EditEndDateTime" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Reason (Optional)</label>
                            <textarea class="form-control" @bind="activeEditor.EditReason" placeholder="e.g., Spring break, Maintenance, etc." rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="@(() => activeEditor.CloseModal())">Cancel</button>
                        <button type="button" class="btn btn-primary" @onclick="@(() => activeEditor.SaveException())">Save</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

<style>
    .modal-backdrop {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        right: 0 !important;
        bottom: 0 !important;
        z-index: 9998 !important;
        width: 100% !important;
        height: 100% !important;
        background-color: rgba(0, 0, 0, 0.5) !important;
    }
</style>
</div>
