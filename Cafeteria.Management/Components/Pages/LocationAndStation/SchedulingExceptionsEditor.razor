@using Cafeteria.Management.Components.Shared

<Toast Message="@ToastMessage"
       Type="@CurrentToastType"
       IsVisible="@ShowToast"
       OnClose="@(() => ShowToast = false)" />

<ConfirmationModal Title="Delete Exception"
                   Message="Are you sure you want to delete this exception?"
                   ConfirmText="Delete"
                   IsVisible="@ShowDeleteConfirmation"
                   OnConfirm="ConfirmDelete"
                   OnCancel="CancelDelete" />

@if (Exceptions.Any())
{
    <table class="table table-sm table-bordered exceptions-table">
        <thead>
            <tr>
                <th>Start Date/Time</th>
                <th>End Date/Time</th>
                <th>Duration</th>
                <th>Reason</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var exception in Exceptions)
            {
                <tr>
                    <td>@exception.StartDateTime.ToString("g")</td>
                    <td>@exception.EndDateTime.ToString("g")</td>
                    <td>
                        @{
                            var duration = exception.EndDateTime - exception.StartDateTime;
                            @if (duration.TotalDays >= 1)
                            {
                                <span>@Math.Floor(duration.TotalDays) day(s) @duration.Hours hour(s)</span>
                            }
                            else
                            {
                                <span>@duration.Hours hour(s) @duration.Minutes min(s)</span>
                            }
                        }
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(exception.Reason))
                        {
                            <span>@exception.Reason</span>
                        }
                        else
                        {
                            <span class="text-muted fst-italic">No reason provided</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => HandleEdit(exception)"><i class="bi bi-pencil me-1"></i>Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => HandleDelete(exception)"><i class="bi bi-trash me-1"></i>Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No exceptions defined.</p>
}

<button class="btn btn-sm btn-outline-success mt-2" @onclick="HandleAdd"><i class="bi bi-plus-circle me-1"></i>Add Exception</button>