@page "/drinks"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@using Cafeteria.Management.Components.Shared
@using Cafeteria.Management.Components.Pages.Drink

<PageTitle>Drinks</PageTitle>

<div class="px-3">
    <div class="d-flex justify-content-center align-items-center">
        <h1 class="page-title fw-bold mb-0">Drinks</h1>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-10">
            <label class="form-label mb-0 me-2 text-nowrap fw-medium">Search:</label>
            <div class="d-flex align-items-center">
                <input type="text" class="form-control" placeholder="Search drinks..." @oninput="OnSearchChanged" value="@searchText" />
            </div>
        </div>
        <div class="col-12 col-md-2">
            <div class="d-flex justify-content-end align-items-center mt-4">
                <button type="button" class="btn btn-primary d-inline-flex align-items-center" @onclick="HandleCreateClick">
                    <i class="bi bi-plus-circle me-2"></i>Add Drink
                </button>
            </div>
        </div>
    </div>

    @if (FilteredDrinks.Any())
    {
        <div class="row g-4 mb-4">
            @foreach (var drink in FilteredDrinks)
            {
                <div class="col-12 col-md-6 col-lg-4" @key="drink.Id">
                    <div class="drink-card card h-100 border-1 rounded-3 shadow-sm">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3 pb-3 border-bottom">
                                <div class="flex-grow-1">
                                    <h5 class="drink-name fw-semibold mb-2">@drink.DrinkName</h5>
                                    <p class="drink-description text-muted small mb-0">@drink.DrinkDescription</p>
                                </div>
                                <div class="drink-price ms-3 fs-4 fw-bold text-nowrap">$@drink.DrinkPrice.ToString("F2")</div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-3 py-2">
                                <span class="detail-label text-muted text-uppercase small fw-medium">Status:</span>
                                <div class="stock-toggle d-flex align-items-center gap-2">
                                    <input type="checkbox"
                                           class="form-check-input"
                                           id="stock-@drink.Id"
                                           checked="@drink.InStock"
                                           @onchange="@(e => ViewModel.ToggleStockStatus(drink.Id, (bool)e.Value!))" />
                                    <label class="form-check-label fw-medium mb-0" for="stock-@drink.Id">
                                        @(drink.InStock ? "In Stock" : "Out of Stock")
                                    </label>
                                </div>
                            </div>

                            <div class="d-flex gap-2 pt-3 border-top">
                                <button type="button" class="btn btn-outline-primary btn-sm flex-fill d-inline-flex align-items-center justify-content-center" @onclick="() => HandleEditClick(drink.Id)">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </button>
                                <button type="button" class="btn btn-outline-danger btn-sm flex-fill d-inline-flex align-items-center justify-content-center" @onclick="() => HandleDeleteClick(drink.Id)">
                                    <i class="bi bi-trash me-1"></i>Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state text-center p-5 bg-white rounded-3 shadow-sm">
            <i class="bi bi-cup-straw fs-1 mb-3 text-muted d-block"></i>
            <p class="fs-5 mb-2">No drinks found.</p>
            <p class="text-muted small mb-0">Click "Add Drink" to create your first drink item.</p>
        </div>
    }
</div>


<CreateOrEditDrink @ref="modalComponent"></CreateOrEditDrink>

<ConfirmationModal IsVisible="ShowDeleteModal" Title="Delete Drink" Message="@DeleteMessage" ConfirmText="Delete"
    OnConfirm="ConfirmDelete" OnCancel="CancelDelete" />

<Toast Message="@toastMessage" Type="@toastType" IsVisible="@showToast" OnClose="@(() => showToast = false)" />